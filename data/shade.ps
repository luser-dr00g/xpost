%!
% Smooth shading (PLRM 4.9.3): shfill paints a shading dictionary
% over the current clip region. The gradient resolves to a stack of
% flat-colour fills through the ordinary paint pipeline: an axial
% shading as bands across its axis, a radial one as circles painted
% outside in, a triangle mesh by recursive subdivision. The band and
% step counts follow the device size of the geometry, so the steps
% stay within a device pixel or two.

/QUIET where { pop }{ (loading shade.ps...)print } ifelse

% t fndict  .fneval  c0..cn-1
% evaluate a PostScript function dictionary at t: exponential
% interpolation (type 2), stitching (type 3), and one-input sampled
% (type 0, byte-aligned sample depths) functions serve the shading
% dictionaries producers write
/.fneval {
    10 dict begin
    /f exch def
    /d0 f /Domain get 0 get def
    /d1 f /Domain get 1 get def
    dup d0 lt { pop d0 } if
    dup d1 gt { pop d1 } if
    /t exch def
    f /FunctionType get
    dup 2 eq {
        pop
        /c0 f /C0 2 copy known { get }{ pop pop [ 0.0 ] } ifelse def
        /c1 f /C1 2 copy known { get }{ pop pop [ 1.0 ] } ifelse def
        /tn t f /N get exp def
        0 1 c0 length 1 sub { /i exch def
            c0 i get
            c1 i get c0 i get sub tn mul add
        } for
        c0 length
    }{ dup 3 eq {
        pop
        /bs f /Bounds get def
        /k 0 def
        0 1 bs length 1 sub { /j exch def
            t bs j get ge { /k j 1 add def } if
        } for
        /lo k 0 eq { d0 }{ bs k 1 sub get } ifelse def
        /hi k bs length eq { d1 }{ bs k get } ifelse def
        /e0 f /Encode get k 2 mul get def
        /e1 f /Encode get k 2 mul 1 add get def
        hi lo eq { e0 }{ t lo sub hi lo sub div e1 e0 sub mul e0 add } ifelse
        f /Functions get k get .fneval
    }{ 0 eq {
        % sampled with one input: linear interpolation between the
        % bracketing samples
        /size f /Size get 0 get def
        /bps f /BitsPerSample get def
        bps 8 eq bps 16 eq or not { /shfill cvx /rangecheck signalerror } if
        /rng f /Range get def
        /nc rng length 2 idiv def
        /ds f /DataSource get def
        /x t d0 sub d1 d0 sub dup 0 eq { pop 1 } if div
           size 1 sub mul def
        /i0 x floor cvi def
        i0 size 1 sub ge { /i0 size 2 sub def } if
        i0 0 lt { /i0 0 def } if
        /fr x i0 sub def
        /max bps 8 eq { 255 }{ 65535 } ifelse def
        0 1 nc 1 sub { /c exch def
            /sa i0 nc mul c add def
            /sb i0 1 add nc mul c add def
            bps 8 eq {
                ds sa get ds sb get
            }{
                ds sa 2 mul get 8 bitshift ds sa 2 mul 1 add get or
                ds sb 2 mul get 8 bitshift ds sb 2 mul 1 add get or
            } ifelse
            1 index sub fr mul add max div
            rng c 2 mul 1 add get rng c 2 mul get sub mul
            rng c 2 mul get add
        } for
        nc
    }{
        /shfill cvx /rangecheck signalerror
    } ifelse } ifelse } ifelse
    end
} def

% x y fn  .fneval2  c0..cn-1 n
% evaluate a two-input function: a sampled function with a 2-D Size,
% bilinear between the four bracketing samples, or an array of
% two-input single-output functions, one per component
/.fneval2 {
    dup type /arraytype eq {
        4 dict begin
        /fa exch def /yy exch def /xx exch def
        0 1 fa length 1 sub { /k exch def
            xx yy fa k get .fneval2 pop
        } for
        fa length
        end
    }{
        16 dict begin
        /f exch def
        /yy exch def /xx exch def
        f /FunctionType get 0 ne { /shfill cvx /rangecheck signalerror } if
        /d f /Domain get def
        xx d 0 get 2 copy lt { exch } if pop d 1 get 2 copy gt { exch } if pop /xx exch def
        yy d 2 get 2 copy lt { exch } if pop d 3 get 2 copy gt { exch } if pop /yy exch def
        /sx f /Size get 0 get def
        /sy f /Size get 1 get def
        /bps f /BitsPerSample get def
        bps 8 eq bps 16 eq or not { /shfill cvx /rangecheck signalerror } if
        /rng f /Range get def
        /nc rng length 2 idiv def
        /ds f /DataSource get def
        /mx bps 8 eq { 255.0 }{ 65535.0 } ifelse def
        /enc f /Encode 2 copy known { get }{ pop pop
            [ 0 sx 1 sub 0 sy 1 sub ] } ifelse def
        /ex xx d 0 get sub d 1 get d 0 get sub dup 0 eq { pop 1 } if div
            enc 1 get enc 0 get sub mul enc 0 get add def
        /ey yy d 2 get sub d 3 get d 2 get sub dup 0 eq { pop 1 } if div
            enc 3 get enc 2 get sub mul enc 2 get add def
        ex 0 lt { /ex 0 def } if
        ex sx 1 sub gt { /ex sx 1 sub def } if
        ey 0 lt { /ey 0 def } if
        ey sy 1 sub gt { /ey sy 1 sub def } if
        /i0 ex floor cvi def
        /j0 ey floor cvi def
        /i1 i0 1 add sx 1 sub 2 copy gt { exch } if pop def
        /j1 j0 1 add sy 1 sub 2 copy gt { exch } if pop def
        /fx ex i0 sub def
        /fy ey j0 sub def
        /samp { % i j c . v  (sample scaled to 0..1)
            3 dict begin
            /c exch def
            sx mul add nc mul c add /si exch def
            bps 8 eq {
                ds si get
            }{
                ds si 2 mul get 8 bitshift ds si 2 mul 1 add get or
            } ifelse mx div
            end
        } def
        0 1 nc 1 sub { /c exch def
            i0 j0 c samp 1 fx sub mul i1 j0 c samp fx mul add
            1 fy sub mul
            i0 j1 c samp 1 fx sub mul i1 j1 c samp fx mul add
            fy mul add
            rng c 2 mul 1 add get rng c 2 mul get sub mul
            rng c 2 mul get add
        } for
        nc
        end
    } ifelse
} def

% shdict  .fnsh  -
% function-based shading (type 1): the domain rectangle, taken
% through the optional Matrix, paints as a grid of cells a few
% device pixels across, each filled flat with the function's colour
% at its centre
/.fnsh {
    14 dict begin
    /sh exch def
    /fn sh /Function get def
    /dom sh /Domain 2 copy known { get }{ pop pop [ 0 1 0 1 ] } ifelse def
    sh /Matrix 2 copy known { get concat }{ pop pop } ifelse
    /x0 dom 0 get def /x1 dom 1 get def
    /y0 dom 2 get def /y1 dom 3 get def
    /nx x1 x0 sub 0 dtransform dup mul exch dup mul add sqrt
        3 div ceiling cvi 1 2 copy lt { exch } if pop 200 2 copy gt { exch } if pop def
    /ny 0 y1 y0 sub dtransform dup mul exch dup mul add sqrt
        3 div ceiling cvi 1 2 copy lt { exch } if pop 200 2 copy gt { exch } if pop def
    /dx x1 x0 sub nx div def
    /dy y1 y0 sub ny div def
    0 1 nx 1 sub { /i exch def
        0 1 ny 1 sub { /j exch def
            /cx x0 i dx mul add def
            /cy y0 j dy mul add def
            cx dx 2 div add cy dy 2 div add fn .fneval2 pop setcolor
            newpath
            cx cy moveto
            cx dx add cy lineto
            cx dx add cy dy add lineto
            cx cy dy add lineto
            closepath fill
        } for
    } for
    end
} def

% t  .shcolor  -
% set the colour the current shading's function gives at t; a mesh
% shading passes components directly and skips the function
/.shcolor {
    shfn null eq {
        pop
    }{
        shfn .fneval pop setcolor
    } ifelse
} def

% x y  .clipbig  r
% a radius from the given point that covers the whole clip region:
% the farthest corner of the region's box, plus a margin
/.clipbig {
    6 dict begin
    /py exch def /px exch def
    gsave clippath flattenpath pathbbox grestore
    /y1 exch def /x1 exch def /y0 exch def /x0 exch def
    x0 px sub dup mul y0 py sub dup mul add sqrt
    x0 px sub dup mul y1 py sub dup mul add sqrt
    2 copy lt { exch } if pop
    x1 px sub dup mul y0 py sub dup mul add sqrt
    2 copy lt { exch } if pop
    x1 px sub dup mul y1 py sub dup mul add sqrt
    2 copy lt { exch } if pop
    1 add
    end
} def

% shdict  .axialsh  -
% bands across the axis, each a strip of the plane perpendicular to
% it, painted with the function's colour at its midpoint; extended
% ends paint half-plane caps in the end colours
/.axialsh {
    20 dict begin
    /sh exch def
    /shfn sh /Function get def
    /co sh /Coords get def
    /x0 co 0 get def /y0 co 1 get def
    /x1 co 2 get def /y1 co 3 get def
    /t0 sh /Domain 2 copy known { get 0 get }{ pop pop 0 } ifelse def
    /t1 sh /Domain 2 copy known { get 1 get }{ pop pop 1 } ifelse def
    /ex sh /Extend 2 copy known { get }{ pop pop [ false false ] } ifelse def
    /dx x1 x0 sub def
    /dy y1 y0 sub def
    /len dx dy dtransform dup mul exch dup mul add sqrt def
    len 0 ne {
    /nb len round cvi 16 2 copy lt { exch } if pop
        256 2 copy gt { exch } if pop def
    % unit vectors along and across the axis, and a breadth that
    % covers the clip
    /ax dx dup mul dy dup mul add sqrt def
    /ux dx ax div def
    /uy dy ax div def
    /px uy neg def
    /py ux def
    /big x0 y0 .clipbig def
    /band { % sa sb  (fractions of the axis)  .band  -
        6 dict begin
        /sb exch def /sa exch def
        newpath
        x0 dx sa mul add px big mul add
        y0 dy sa mul add py big mul add moveto
        x0 dx sb mul add px big mul add
        y0 dy sb mul add py big mul add lineto
        x0 dx sb mul add px big mul sub
        y0 dy sb mul add py big mul sub lineto
        x0 dx sa mul add px big mul sub
        y0 dy sa mul add py big mul sub lineto
        closepath fill
        end
    } def
    ex 0 get {
        t0 .shcolor
        big ax div neg 0 band
    } if
    ex 1 get {
        t1 .shcolor
        1 1 big ax div add band
    } if
    0 1 nb 1 sub { /i exch def
        /sa i nb div def
        /sb i 1 add nb div def
        sa sb add 2 div t1 t0 sub mul t0 add .shcolor
        sa sb band
    } for
    } if
    end
} def

% shdict  .radialsh  -
% the circle family painted outside in: each step fills its whole
% circle, the next smaller covering the centre, so the last leaves
% the gradient; an extended outer end floods the clip first and an
% extended inner end is the innermost circle itself
/.radialsh {
    20 dict begin
    /sh exch def
    /shfn sh /Function get def
    /co sh /Coords get def
    /cx0 co 0 get def /cy0 co 1 get def /cr0 co 2 get def
    /cx1 co 3 get def /cy1 co 4 get def /cr1 co 5 get def
    /t0 sh /Domain 2 copy known { get 0 get }{ pop pop 0 } ifelse def
    /t1 sh /Domain 2 copy known { get 1 get }{ pop pop 1 } ifelse def
    /ex sh /Extend 2 copy known { get }{ pop pop [ false false ] } ifelse def
    % step count from the device size of the swept ring
    /nb cx1 cx0 sub cy1 cy0 sub dtransform dup mul exch dup mul add sqrt
        cr1 cr0 sub 0 dtransform dup mul exch dup mul add sqrt add
        round cvi 16 2 copy lt { exch } if pop
        256 2 copy gt { exch } if pop def
    /inout cr1 cr0 ge def
    ex inout { 1 }{ 0 } ifelse get {
        inout { t1 }{ t0 } ifelse .shcolor
        newpath
        inout { cx1 cy1 }{ cx0 cy0 } ifelse
        2 copy .clipbig 0 360 arc fill
    } if
    % paint from the larger circle to the smaller
    nb -1 0 { /i exch def
        /s i nb div def
        inout not { /s 1 s sub def } if
        s t1 t0 sub mul t0 add .shcolor
        newpath
        cx0 cx1 cx0 sub s mul add
        cy0 cy1 cy0 sub s mul add
        cr0 cr1 cr0 sub s mul add
        dup 0 gt { 0 360 arc fill }{ pop pop pop } ifelse
    } for
    end
} def

% mesh vertex readers: the packed DataSource walks byte-aligned
% fields through a position held in the reader dictionary
/.mrdbyte { % - . v
    ds dp get /dp dp 1 add def
} def
/.mrdbits { % nbits . v  (16 or 32, accumulated in a real)
    0.0 exch 8 idiv { 256 mul .mrdbyte add } repeat
} def
/.mrddec { % k nbits . value  (field k of Decode applied)
    dup .mrdbits
    exch dup 8 eq { pop 255.0 }{
         16 eq { 65535.0 }{ 4294967295.0 } ifelse } ifelse div
    /frv exch def /kk exch def
    dec kk 2 mul 1 add get dec kk 2 mul get sub frv mul
    dec kk 2 mul get add
} def
/.mrdpt { % - . [x y]
    [ 0 bpc .mrddec 1 bpc .mrddec ]
} def
/.mrdcolor { % - . [c0..cn-1]
    [ 0 1 ncomp 1 sub { /c exch def
        c 2 add bpcm .mrddec
    } for ]
} def
/.mrdvertex { % - . [x y c0..cn-1]
    [ .mrdpt aload pop .mrdcolor aload pop ]
} def

% [c0..cn-1]  .gsetcolor  -
% set a mesh colour: components directly, or -- when the shading
% carries a Function -- a single parametric value through it. The
% mesh painters bind /shfn before any triangle paints
/.gsetcolor {
    shfn null eq {
        aload pop setcolor
    }{
        0 get shfn .fneval pop setcolor
    } ifelse
} def

% va vb vc depth  .gtri  -
% paint a Gouraud triangle: subdivide at the edge midpoints until the
% triangle sits within a couple of device pixels, then fill flat with
% the corner average
/.gmid { % va vb . vm
    2 dict begin
    /b exch def /a exch def
    [ 0 1 a length 1 sub { /i exch def
        a i get b i get add 2 div
    } for ]
    end
} def
/.gtri {
    6 dict begin
    /dpt exch def /vc exch def /vb exch def /va exch def
    /dd 0 def
    2 1 va length 1 sub { /i exch def
        va i get vb i get sub abs dup dd gt { /dd exch def }{ pop } ifelse
        va i get vc i get sub abs dup dd gt { /dd exch def }{ pop } ifelse
    } for
    dpt 0 le dd 0.015 le or {
        % flat: fill with the corner average
        [ 2 1 va length 1 sub { /i exch def
            va i get vb i get add vc i get add 3 div
        } for ] .gsetcolor
        newpath
        va 0 get va 1 get moveto
        vb 0 get vb 1 get lineto
        vc 0 get vc 1 get lineto
        closepath fill
    }{
        /mab va vb .gmid def
        /mbc vb vc .gmid def
        /mca vc va .gmid def
        va mab mca dpt 1 sub .gtri
        mab vb mbc dpt 1 sub .gtri
        mca mbc vc dpt 1 sub .gtri
        mab mbc mca dpt 1 sub .gtri
    } ifelse
    end
} def

% shdict  .meshsh  -
% free-form (type 4) and lattice-form (type 5) triangle meshes with
% per-vertex colours
/.meshsh {
    20 dict begin
    /sh exch def
    /shfn sh /Function 2 copy known { get }{ pop pop null } ifelse def
    /ds sh /DataSource get def
    /dp 0 def
    /dec sh /Decode get def
    /bpc sh /BitsPerCoordinate get def
    /bpcm sh /BitsPerComponent get def
    /ncomp dec length 4 sub 2 idiv def
    bpc 16 eq bpc 32 eq or
    bpcm 8 eq bpcm 16 eq or and not {
        /shfill cvx /rangecheck signalerror
    } if
    % subdivision depth from the mesh's device scale: two levels
    % within a few pixels, four when triangles are large
    /dpt 4 def
    sh /ShadingType get 5 eq {
        /vpr sh /VerticesPerRow get def
        /prev null def
        {
            dp ds length ge { exit } if
            /row [ vpr { .mrdvertex } repeat ] def
            prev null ne {
                0 1 vpr 2 sub { /i exch def
                    prev i get prev i 1 add get row i get dpt .gtri
                    prev i 1 add get row i get row i 1 add get dpt .gtri
                } for
            } if
            /prev row def
        } loop
    }{
        /va null def /vb null def /vc null def
        {
            dp ds length ge { exit } if
            /flag sh /BitsPerFlag get .mrdbits cvi def
            flag 0 eq {
                dp ds length ge { exit } if
                /va .mrdvertex def
                sh /BitsPerFlag get .mrdbits pop
                /vb .mrdvertex def
                sh /BitsPerFlag get .mrdbits pop
                /vc .mrdvertex def
            }{
                flag 1 eq {
                    /va vb def /vb vc def
                }{
                    /vb vc def
                } ifelse
                /vc .mrdvertex def
            } ifelse
            va vb vc dpt .gtri
        } loop
    } ifelse
    end
} def

% a0 a1 a2 a3 t  .bez1  v
% a cubic Bezier component at parameter t
/.bez1 {
    5 dict begin
    /t exch def /a3 exch def /a2 exch def /a1 exch def /a0 exch def
    /u 1 t sub def
    a0 u u mul u mul mul
    a1 3 mul u u mul t mul mul add
    a2 3 mul u t t mul mul mul add
    a3 t t mul t mul mul add
    end
} def

% the 4x4 control grid slot (row-major, rows pairing with u) for
% each patch point p1..p16 in the data-stream order: the boundary
% counterclockwise from the first corner, then the four interior
% points
/.pgridmap [ 0 1 2 3 7 11 15 14 13 12 8 4 5 6 10 9 ] def

% [w slot w slot ...]  .pmix  [x y]
% a weighted combination of grid points, divided by 9: the Coons
% interior points are ninths of boundary sums
/.pmix {
    4 dict begin
    /spec exch def
    /sx 0 def /sy 0 def
    0 2 spec length 2 sub { /i exch def
        /w spec i get def
        /p g spec i 1 add get get def
        /sx sx p 0 get w mul add def
        /sy sy p 1 get w mul add def
    } for
    [ sx 9 div sy 9 div ]
    end
} def

% -  .patchpaint  -
% paint the current 4x4 grid g with corner colours cols: collapse
% the grid's columns at each u by .bez1, sweep the resulting curve
% in v, and hand the cells to the Gouraud triangles with corner
% colours blended bilinearly
/.patchpaint {
    10 dict begin
    % subdivision from the device size of the boundary points
    /mnx 9e99 def /mny 9e99 def /mxx -9e99 def /mxy -9e99 def
    0 1 11 { .pgridmap exch get g exch get aload pop transform
        dup mxy gt { dup /mxy exch def } if dup mny lt { dup /mny exch def } if pop
        dup mxx gt { dup /mxx exch def } if dup mnx lt { dup /mnx exch def } if pop
    } for
    /n mxx mnx sub mxy mny sub 2 copy lt { exch } if pop
       6 div ceiling cvi
       3 2 copy lt { exch } if pop
       12 2 copy gt { exch } if pop def
    /verts [ 0 1 n { /iu exch def
        /u iu n div def
        /q [ 0 1 3 { /j exch def
            [ g j get 0 get g j 4 add get 0 get
              g j 8 add get 0 get g j 12 add get 0 get u .bez1
              g j get 1 get g j 4 add get 1 get
              g j 8 add get 1 get g j 12 add get 1 get u .bez1 ]
        } for ] def
        [ 0 1 n { /iv exch def
            /v iv n div def
            [
            q 0 get 0 get q 1 get 0 get q 2 get 0 get q 3 get 0 get v .bez1
            q 0 get 1 get q 1 get 1 get q 2 get 1 get q 3 get 1 get v .bez1
            0 1 ncomp 1 sub { /c exch def
                cols 0 get c get 1 u sub mul 1 v sub mul
                cols 1 get c get 1 u sub mul v mul add
                cols 2 get c get u mul v mul add
                cols 3 get c get u mul 1 v sub mul add
            } for
            ]
        } for ]
    } for ] def
    0 1 n 1 sub { /iu exch def
        0 1 n 1 sub { /iv exch def
            verts iu get iv get
            verts iu 1 add get iv get
            verts iu get iv 1 add get
            3 .gtri
            verts iu 1 add get iv get
            verts iu 1 add get iv 1 add get
            verts iu get iv 1 add get
            3 .gtri
        } for
    } for
    end
} def

% shdict  .patchsh  -
% Coons (type 6) and tensor-product (type 7) patch meshes. A Coons
% patch completes to a tensor patch by the standard interior points,
% so one surface serves both
/.patchsh {
    30 dict begin
    /sh exch def
    /shfn sh /Function 2 copy known { get }{ pop pop null } ifelse def
    /ds sh /DataSource get def
    /dp 0 def
    /dec sh /Decode get def
    /bpc sh /BitsPerCoordinate get def
    /bpcm sh /BitsPerComponent get def
    /bpf sh /BitsPerFlag get def
    /ncomp dec length 4 sub 2 idiv def
    /tensor sh /ShadingType get 7 eq def
    bpc 16 eq bpc 32 eq or
    bpcm 8 eq bpcm 16 eq or and not {
        /shfill cvx /rangecheck signalerror
    } if
    % pts: p1..p16 as [x y] in data order; cols: c1..c4; g: the grid
    /pts 16 array def
    /cols 4 array def
    /g 16 array def
    /np tensor { 15 }{ 11 } ifelse def
    {
        dp ds length ge { exit } if
        /flag bpf .mrdbits cvi def
        dp ds length ge { exit } if
        flag 0 eq {
            0 1 np { pts exch .mrdpt put } for
            0 1 3 { cols exch .mrdcolor put } for
        }{
            % the shared edge is the previous patch's: its four
            % points become p1..p4 and its two colours c1..c2
            /oldp [ [ 3 4 5 6 ] [ 6 7 8 9 ] [ 9 10 11 0 ] ] flag 1 sub get
                   [ exch { pts exch get } forall ] def
            /oldc [ [ 1 2 ] [ 2 3 ] [ 3 0 ] ] flag 1 sub get
                   [ exch { cols exch get } forall ] def
            4 1 np { pts exch .mrdpt put } for
            2 1 3 { cols exch .mrdcolor put } for
            0 1 3 { /k exch def pts k oldp k get put } for
            0 1 1 { /k exch def cols k oldc k get put } for
        } ifelse
        0 1 np { /k exch def g .pgridmap k get pts k get put } for
        tensor not {
            % the Coons interior points, as ninths of boundary sums
            g 5 [ -4 0 6 1 6 4 -2 3 -2 12 3 13 3 7 -1 15 ] .pmix put
            g 6 [ -4 3 6 2 6 7 -2 0 -2 15 3 4 3 14 -1 12 ] .pmix put
            g 9 [ -4 12 6 13 6 8 -2 15 -2 0 3 1 3 11 -1 3 ] .pmix put
            g 10 [ -4 15 6 14 6 11 -2 12 -2 3 3 2 3 8 -1 0 ] .pmix put
        } if
        .patchpaint
    } loop
    end
} def

%   shdict  shfill  -
% paint the shading over the current clip region; the current path
% survives untouched
/shfill {
    dup type /dicttype ne { /shfill cvx /typecheck signalerror } if
    gsave
    dup /ColorSpace get setcolorspace
    dup /BBox 2 copy known {
        get
        newpath
        dup 0 get 1 index 1 get moveto
        dup 2 get 1 index 1 get lineto
        dup 2 get 1 index 3 get lineto
        dup 0 get 1 index 3 get lineto
        pop closepath clip newpath
    }{ pop pop } ifelse
    dup /ShadingType get
    dup 1 eq { pop .fnsh }{
    dup 2 eq { pop .axialsh }{
    dup 3 eq { pop .radialsh }{
    dup 4 eq 1 index 5 eq or { pop .meshsh }{
    dup 6 eq exch 7 eq or { .patchsh }{
        pop /shfill cvx /rangecheck signalerror
    } ifelse } ifelse } ifelse } ifelse } ifelse
    grestore
} def

/QUIET where { pop }{ (eof shade.ps\n)print } ifelse
