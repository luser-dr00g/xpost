/QUIET where { pop }{ (loading pdfwrite.ps...)print } ifelse

/newPDFWRITEdevice { % width height  .  IMAGE-device-dict
    PDFWRITE dup /Create get exec
} def

% PDFWRITE writes a single-page vector PDF: the marking methods append
% content-stream operators and Emit wraps them in the PDF file structure.
% This is a clean-room implementation from the published PDF format (operators
% rg/RG/m/l/re/f*/S/cm and the object/xref/trailer layout); no rasterizing.
%
% Coordinates arrive in device space (y-down); the content stream is prefixed
% with the device matrix (1 0 0 -1 0 height cm) so device coordinates map to
% PDF's y-up user space -- the same flip the raster devices apply, done once.
%
% Content is accumulated in a growable buffer held outside virtual memory -- via
% the device's /Private string, like the raster devices' pixel buffer -- so that
% it survives a `restore` the job may execute before showpage (the current
% page's marks are not part of VM). Emit splits it into <=65500-byte strings
% (the PostScript string limit) and deflate-compresses it, falling back to
% uncompressed without zlib.

/PDFWRITE <<
    /nativecolorspace /DeviceRGB
    /dimensions [0 0]
    /NoOutput true  % keep this device's own vector FillPoly (no rasterizing)

    /.copydict {
        dup length dict copy
        dup /width known {
            dup begin
                /dimensions [width height] def
            end
        } if
        /OutputFileName where {
            /OutputFileName exch 1 index get
            3 copy put pop pop
        } if
    } bind

    /Create { % width height IMAGE  .  IMAGE'
    begin {/height /width}{exch def}forall
    currentdict end
    dup /.copydict get exec
    begin
        currentdict .pdfinit    % create the content accumulator (outside VM)
        % first content op: the device matrix mapping device coords to PDF
        % user space (y-up). Part of the content so it compresses with the rest.
        (1 0 0 -1 0 ) .put height cvi 20 string cvs .put ( cm\n) .put
    currentdict
    end } bind

    /Destroy { % IMAGE  .  -
        dup .pdffree pop
    } bind

    /.zeros (0000000000) def

    % append a string to the content accumulator (held outside VM via /Private)
    /.put { % str  .  -
        currentdict .pdfput
    } bind

    % append a number in PDF syntax (integer, or two decimals; never
    % exponential). round(n*100) avoids binary-float print noise.
    /.pdfnum { % num  .  -
        dup truncate 1 index eq {
            cvi 20 string cvs .put
        }{
            100 mul round cvi
            dup 0 lt { (-) .put neg } if
            dup 100 idiv 20 string cvs .put
            (.) .put
            100 mod
            dup 10 lt { (0) .put } if
            20 string cvs .put
        } ifelse
    } bind

    /PutPix { % r g b x y IMAGE  .  -
    begin {y x b g r}{exch def}forall
        r .pdfnum ( ) .put g .pdfnum ( ) .put b .pdfnum ( rg\n) .put
        x .pdfnum ( ) .put y .pdfnum ( 1 1 re\nf\n) .put
    end }

    /GetPix { % x y IMAGE  .  r g b
        pop pop pop  0 0 0
    }

    /DrawLine { % r g b x1 y1 x2 y2 IMAGE  .  -
    begin {y2 x2 y1 x1 b g r}{exch def}forall
        r .pdfnum ( ) .put g .pdfnum ( ) .put b .pdfnum ( RG\n) .put
        x1 .pdfnum ( ) .put y1 .pdfnum ( m\n) .put
        x2 .pdfnum ( ) .put y2 .pdfnum ( l\nS\n) .put
    end }

    /DrawRect { % r g b x y w h IMAGE  .  -
    begin {h w y x b g r}{exch def}forall
        r .pdfnum ( ) .put g .pdfnum ( ) .put b .pdfnum ( RG\n) .put
        x .pdfnum ( ) .put y .pdfnum ( ) .put
        w .pdfnum ( ) .put h .pdfnum ( re\nS\n) .put
    end }

    /FillRect { % r g b x y w h IMAGE  .  -
    begin {h w y x b g r}{exch def}forall
        r .pdfnum ( ) .put g .pdfnum ( ) .put b .pdfnum ( rg\n) .put
        x .pdfnum ( ) .put y .pdfnum ( ) .put
        w .pdfnum ( ) .put h .pdfnum ( re\nf\n) .put
    end }

    % r g b polygon IMAGE . -  ; append "r g b rg", the subpath moveto/lineto/
    % closepath, and an even-odd fill. The per-coordinate formatting is the hot
    % loop, so it is done in C (.pdffillpoly), appending to the accumulator.
    /FillPoly { .pdffillpoly } bind

    /Emit { % IMAGE  .  -
    begin
        /Chunks currentdict .pdfchunks def
        % deflate the content stream (falls back to uncompressed without zlib)
        Chunks .flatecompress /flated exch def /Chunks exch def
        /F /OutputFileName where { pop OutputFileName (w) file }{ (%stdout) (w) file } ifelse def
        /BytePos 0 def

        /hs height cvi 20 string cvs def
        /ws width cvi 20 string cvs def
        /clen 0 def
        Chunks { length /clen exch clen add def } forall

        % write a string to F and advance the byte counter
        /.w { dup F exch writestring length /BytePos BytePos 3 -1 roll add def } def
        % write a 10-digit zero-padded offset
        /.woff { 20 string cvs /n exch def
                 .zeros 0 10 n length sub getinterval .w  n .w } def

        (%PDF-1.4\n) .w
        /off1 BytePos def
        (1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n) .w
        /off2 BytePos def
        (2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n) .w
        /off3 BytePos def
        (3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ) .w ws .w ( ) .w hs .w
        (] /Contents 4 0 R /Resources << >> >>\nendobj\n) .w
        /off4 BytePos def
        (4 0 obj\n<< /Length ) .w clen 20 string cvs .w
        flated { ( /Filter /FlateDecode) .w } if
        ( >>\nstream\n) .w
        Chunks { .w } forall
        (\nendstream\nendobj\n) .w
        /xoff BytePos def
        (xref\n0 5\n0000000000 65535 f \n) .w
        off1 .woff ( 00000 n \n) .w
        off2 .woff ( 00000 n \n) .w
        off3 .woff ( 00000 n \n) .w
        off4 .woff ( 00000 n \n) .w
        (trailer\n<< /Size 5 /Root 1 0 R >>\nstartxref\n) .w xoff 20 string cvs .w (\n%%EOF\n) .w

        F (%stdout) (w) file ne { F closefile } if
    end }
>> def

/TESTGRAPHICS where {pop
    (TESTGRAPHICS pdfwrite)=
    /dev 200 200 newPDFWRITEdevice def
    0 0 0 [ [20 20] [80 20] [80 80] [20 80] ] dev dup /FillPoly get exec
    dev .pdfchunks 0 get length 0 gt { (pdfwrite content PASS)= }{ (pdfwrite content FAIL)= } ifelse
    dev dup /Destroy get exec
} if

/QUIET where { pop }{ (eof pdfwrite.ps\n)print } ifelse
