/QUIET where { pop }{ (loading paint.ps...)print } ifelse

% Painting Operators

% -  erasepage  -
% paint current page white
/erasepage {
    % a device with an Erase method resets the page itself (the alpha
    % device clears to transparent); otherwise paint the page white
    DEVICE /Erase known {
        DEVICE dup /Erase get exec
        flushpage
    }{
    gsave
        1 setgray
        [ currentcolordict DEVICE /nativecolorspace get
        get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        0 0 DEVICE /dimensions get aload pop
        DEVICE dup /FillRect get exec
        pop
        flushpage
    grestore
    } ifelse
} bind def

% -  fill  -
% fill current path with current color
% A device with a FillPath method consumes the whole path itself
% (vector devices fill with curves preserved). The path must lie
% inside a rectangular clip: a non-trivial clip region is cut by the
% polygon machinery below, at the cost of flattening.
/fill {
    closepath
    DEVICE /FillPath known .cliptrivial and {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        DEVICE dup /FillPath get exec
        pop
        flushpage
        newpath
    }{
    flattenpath
    % subpaths merged into one point list, separated by null, so that
    % FillPoly scans them together and interior subpaths produce holes.
    % A non-trivial clip region intersects span-by-span in the same
    % scan-conversion the fill itself uses: exact for any region the
    % nonzero rule can describe (disjoint windows, concave boundaries,
    % counters), where the half-plane clipper serves only convex ones
    .fillpolyargs
    .cliptrivial not {
        .clippolyargs .clipfillpoly
    } if
    /DEBUGFILL where { pop
        (fill)=
        pstack()=
        hook
    } if

    dup length 2 gt {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        counttomark 2 add -1 roll
        DEVICE dup /FillPoly get exec
        pop
        %pstack()=
    }{
        pop
    } ifelse

    flushpage
    newpath
    } ifelse
} bind def

% -  eofill  -
% fill using the even-odd rule
% The even-odd interior resolves to pixel-band rectangles through the
% same scan-conversion as the nonzero fill, and the rectangles --
% winding-uniform -- then travel the ordinary pipeline: clip span
% intersection and the device FillPoly. A vector device consuming
% whole paths through FillPath still receives the nonzero
% approximation, as before.
/eofill {
    DEVICE /FillPath known .cliptrivial and {
        fill
    }{
        closepath
        flattenpath
        .fillpolyargs .eospanpoly
        .cliptrivial not {
            .clippolyargs .clipfillpoly
        } if

        dup length 2 gt {
            [ currentcolordict DEVICE /nativecolorspace get get exec
            counttomark { currenttransfer exec counttomark 1 roll } repeat
            counttomark 2 add -1 roll
            DEVICE dup /FillPoly get exec
            pop
        }{
            pop
        } ifelse

        flushpage
        newpath
    } ifelse
} bind def

% -  stroke  -
% draw line along current path
% A device with a StrokePath method consumes the whole path itself
% (vector devices stroke with true joins, caps and width); raster
% devices take the hairline DrawLine walk when the device-space width
% is within a pixel, else the stroked outline is filled.
/stroke {
    DEVICE /StrokePath known {
        % dashing and non-rectangular clipping consume line segments;
        % with neither active the path passes through unflattened, so
        % curves reach the device
        currentdash pop length 0 eq .cliptrivial and not {
            flattenpath
            dashpath
            doclip
        } if
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        DEVICE dup /StrokePath get exec
        pop
        flushpage
        newpath
    }{
    currentlinewidth 0 dtransform
    dup mul exch dup mul exch add sqrt
        1 le {
        flattenpath
        dashpath
        doclip
        mark
        {          % x0 y0 
            2 copy % x0 y0 x0 y0
            %pstack(M)=
        }
        {          % ... xN-1 yN-1 xN yN
            4 copy % ... xN-1 yN-1 xN yN xN-1 yN-1 xN yN
            [ currentcolordict DEVICE /nativecolorspace get get exec
            counttomark { currenttransfer exec counttomark 1 roll } repeat
            counttomark 5 add -4 roll
            %5 1 roll  % ... xN-1 yN-1 xN yN gray xN-1 yN-1 xN yN
            %pstack(L)=
            DEVICE dup /DrawLine get exec  % ... xN-1 yN-1 xN yN
            pop
            4 2 roll pop pop % ... xN yN
        }
        {}
        {            % x0 y0 xN yN
            4 2 roll % xN yN x0 y0
            [ currentcolordict DEVICE /nativecolorspace get get exec
            counttomark { currenttransfer exec counttomark 1 roll } repeat
            counttomark 5 add -4 roll
            %5 1 roll % gray xN yN x0 y0
            %pstack(C)=
            DEVICE dup /DrawLine get exec  % -
            pop
        }
        .devpathforall
        cleartomark
        flushpage
    }{
        strokepath
        fill
    } ifelse

    newpath
    } ifelse
} bind def

% Sample collectors: normalize the packed source data to one byte per
% sample in buf. Samples pack high-order first within each byte, and
% every row of samples begins on a byte boundary (PLRM 4.10), so a
% sub-byte depth walks each byte's groups from the top and drops the
% pad bits once a row's samples are down. The procedures run inside
% .imagepaint's dictionary, where width, ncomp, buf, bz, bp and the
% row counters rowsamples and rs are defined.
/bitsdict <<
    1 {
        {
            bp bz ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            { % char
                7 -1 0 { % char i
                    rs rowsamples lt bp bz lt and {
                        2 copy neg bitshift 1 and 255 mul
                        buf exch bp exch put
                        /bp bp 1 add def
                        /rs rs 1 add def
                    } if
                    pop
                } for
                pop
                rs rowsamples ge { /rs 0 def } if
            } forall
        } loop
    }
    2 {
        {
            bp bz ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            { % char
                6 -2 0 { % char i
                    rs rowsamples lt bp bz lt and {
                        2 copy neg bitshift 3 and 85 mul
                        buf exch bp exch put
                        /bp bp 1 add def
                        /rs rs 1 add def
                    } if
                    pop
                } for
                pop
                rs rowsamples ge { /rs 0 def } if
            } forall
        } loop
    }
    4 {
        {
            bp bz ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            { % char
                4 -4 0 { % char i
                    rs rowsamples lt bp bz lt and {
                        2 copy neg bitshift 15 and 17 mul
                        buf exch bp exch put
                        /bp bp 1 add def
                        /rs rs 1 add def
                    } if
                    pop
                } for
                pop
                rs rowsamples ge { /rs 0 def } if
            } forall
        } loop
    }
    8 {
        {
            bp bz ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            dup length bp add bz gt {
                0 bz bp sub getinterval
            } if
            buf exch bp exch
            dup length bp add /bp exch def
            putinterval
        } loop
    }
    12 {
    }
>> def

% src  .imgsource  proc
% normalize an image data source: a file becomes a chunk-reading
% procedure, a string a procedure delivering it, a procedure passes
% through unchanged
/.imgsource {
    dup type /filetype eq {
        [ exch 4096 string /readstring cvx /pop cvx ] cvx
    }{
        dup type /stringtype eq {
            [ exch ] cvx
        } if
    } ifelse
} def

% -  .ncomponents  n
% the number of colour components the current colour space takes
/.spacecomps <<
    /DeviceGray 1
    /DeviceRGB 3
    /DeviceCMYK 4
>> def
/.ncomponents {
    currentcolorspace
    dup type /arraytype eq {
        dup 0 get /Separation eq { pop 1 }{
        dup 0 get /DeviceN eq { 1 get length }{
        0 get //.spacecomps exch get } ifelse } ifelse
    }{
        //.spacecomps exch get
    } ifelse
} def

% width height bits mat datasrc decode ncomp  .imagepaint  -
% the shared image painter: the collectors normalize every sample
% depth to one byte, so each pixel reads ncomp bytes, maps each
% through its Decode range, and delivers the components to setcolor
% in the current colour space
/.imagepaint {
    gsave
        newpath
        14 dict begin
        {ncomp decode datasrc mat bits height width}{exch def}forall

        /bz width height mul ncomp mul def
        /buf bz string def
        /bp 0 def
        /rowsamples width ncomp mul def
        /rs 0 def

        bitsdict bits get exec

        % per-component decode as base + sample x scale over 0..255
        /dbase ncomp array def
        /dscale ncomp array def
        0 1 ncomp 1 sub { /c exch def
            /dmin decode c 2 mul get def
            dbase c dmin put
            dscale c decode c 2 mul 1 add get dmin sub 255 div put
        } for

        mat mat invertmatrix concat
        0 1 height 1 sub { /y exch def
            0 1 width 1 sub { /x exch def
                /base y width mul x add ncomp mul def
                0 1 ncomp 1 sub { /c exch def
                    buf base c add get dscale c get mul dbase c get add
                } for
                setcolor
                x y 1 1 rectfill
            } for
        } for

        end
    grestore
} def

% width height bits/sample matrix datasrc  image  -
%                                imagedict  image  -
% The five-operand form paints grey samples; the dictionary form
% (ImageType 1, a single DataSource) paints samples in the colour
% space current when image is invoked
/image {
    dup type /dicttype eq {
        begin
        ImageType 1 ne { end /image cvx /rangecheck signalerror } if
        currentdict /MultipleDataSources known
            { MultipleDataSources }{ false } ifelse {
            end /image cvx /typecheck signalerror
        } if
        Width Height BitsPerComponent ImageMatrix
        DataSource .imgsource
        Decode
        end
        .ncomponents .imagepaint
    }{
        gsave
        /DeviceGray setcolorspace
        .imgsource [ 0 1 ] 1 .imagepaint
        grestore
    } ifelse
} def

% width height polarity matrix datasrc  .stencilmask  -
% paint the current colour through a one-bit stencil: samples equal to
% the polarity mark unit squares of image space, the rest leave the
% page untouched. Each row of samples begins on a byte boundary.
/.stencilmask {
    gsave
        newpath
        10 dict begin
        {datasrc mat polarity height width}{exch def}forall
        /rowbytes width 7 add 8 idiv def
        /buf rowbytes height mul string def
        /bp 0 def
        { % collect the sample data
            bp buf length ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            dup length bp add buf length gt {
                0 buf length bp sub getinterval
            } if
            buf exch bp exch
            dup length bp add /bp exch def
            putinterval
        } loop
        mat mat invertmatrix concat
        /ink polarity {1}{0} ifelse def
        0 1 height 1 sub { /y exch def
            0 1 width 1 sub { /x exch def
                buf y rowbytes mul x 8 idiv add get
                x 8 mod 7 sub bitshift 1 and
                ink eq {
                    x y 1 1 rectfill
                } if
            } for
        } for
        end
    grestore
} def

% width height polarity matrix datasrc  imagemask  -
%                                  maskdict  imagemask  -
% The dictionary form (ImageType 1) states its polarity through
% Decode: [1 0] paints where the sample is one, as operand polarity
% true does; [0 1] paints the zeroes
/imagemask {
    dup type /dicttype eq {
        begin
        ImageType 1 ne { end /imagemask cvx /rangecheck signalerror } if
        Width Height
        Decode 0 get 0 ne
        ImageMatrix
        DataSource .imgsource
        end
    }{
        .imgsource
    } ifelse
    .stencilmask
} def

/QUIET where { pop }{ (eof paint.ps\n)print } ifelse
