/QUIET where { pop }{ (loading paint.ps...)print } ifelse

% mark c1..cn  .applytransfer  mark c1'..cn'
% the transfer procedures, one per channel: three components map to
% the red, green and blue transfers, four to red, green, blue and
% grey in the CMYK order, anything else through the grey transfer
/.applytransfer {
    .refreshscreencell
    counttomark 3 eq {
        graphicsdict /currgstate get /bluetransfer get exec
        3 1 roll
        graphicsdict /currgstate get /greentransfer get exec
        3 1 roll
        graphicsdict /currgstate get /redtransfer get exec
        3 1 roll
    }{
    counttomark 4 eq {
        currenttransfer exec 4 1 roll
        graphicsdict /currgstate get /bluetransfer get exec 4 1 roll
        graphicsdict /currgstate get /greentransfer get exec 4 1 roll
        graphicsdict /currgstate get /redtransfer get exec 4 1 roll
    }{
        counttomark { currenttransfer exec counttomark 1 roll } repeat
    } ifelse } ifelse
} def

% Painting Operators

% -  erasepage  -
% paint current page white
/erasepage {
    % a device with an Erase method resets the page itself (the alpha
    % device clears to transparent); otherwise paint the page white
    DEVICE /Erase known {
        DEVICE dup /Erase get exec
        flushpage
    }{
    gsave
        1 setgray
        [ currentcolordict DEVICE /nativecolorspace get
        get exec
        .applytransfer
        0 0 DEVICE /dimensions get aload pop
        DEVICE dup /FillRect get exec
        pop
        flushpage
    grestore
    } ifelse
} bind def

% -  fill  -
% fill current path with current color
% A device with a FillPath method consumes the whole path itself
% (vector devices fill with curves preserved). The path must lie
% inside a rectangular clip: a non-trivial clip region is cut by the
% polygon machinery below, at the cost of flattening.
/fill {
    .patternactive { .patternfill }{
    closepath
    DEVICE /FillPath known .cliptrivial and {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        .applytransfer
        DEVICE dup /FillPath get exec
        pop
        flushpage
        newpath
    }{
    flattenpath
    % subpaths merged into one point list, separated by null, so that
    % FillPoly scans them together and interior subpaths produce holes.
    % A rectangular clip region is a single convex window: clip the fill
    % polygon against it geometrically, so it stays whole rectangles
    % rather than dissolving into per-scanline bands -- which a vector
    % device would otherwise emit as one subpath per row. A disjoint or
    % concave clip region has no single convex half-plane set, so it
    % intersects span-by-span in the fill's own scan-conversion, exact
    % for any region the nonzero rule can describe.
    .cliptrivial not {
        .cliprect { pop pop pop pop true }{ false } ifelse {
            doclip .fillpolyargs
        }{
            .fillpolyargs .clippolyargs .clipfillpoly
        } ifelse
    }{
        .fillpolyargs
    } ifelse
    /DEBUGFILL where { pop
        (fill)=
        pstack()=
        hook
    } if

    dup length 2 gt {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        .applytransfer
        counttomark 2 add -1 roll
        DEVICE dup /FillPoly get exec
        pop
        %pstack()=
    }{
        pop
    } ifelse

    flushpage
    newpath
    } ifelse
    } ifelse
} bind def

% -  eofill  -
% fill using the even-odd rule
% The even-odd interior resolves to pixel-band rectangles through the
% same scan-conversion as the nonzero fill, and the rectangles --
% winding-uniform -- then travel the ordinary pipeline: clip span
% intersection and the device FillPoly. A vector device consuming
% whole paths through FillPath carries the rule to its consumer.
/eofill {
    .patternactive { .patterneofill }{
    DEVICE /FillPath known .cliptrivial and {
        graphicsdict /currgstate get /.eorule true put
        % this implementation's own fill, immune to a program's
        % redefinition of the name (which may itself invoke eofill)
        //fill exec
        graphicsdict /currgstate get /.eorule false put
    }{
        closepath
        flattenpath
        .fillpolyargs .eospanpoly
        .cliptrivial not {
            .clippolyargs .clipfillpoly
        } if

        dup length 2 gt {
            [ currentcolordict DEVICE /nativecolorspace get get exec
            .applytransfer
            counttomark 2 add -1 roll
            DEVICE dup /FillPoly get exec
            pop
        }{
            pop
        } ifelse

        flushpage
        newpath
    } ifelse
    } ifelse
} bind def

% x y proc  .intest  bool
% upath proc  .intest  bool
% The insideness core: proc resolves the subject region -- the spans
% the corresponding painting operator would mark -- and the probe is
% either the device pixel holding the point or the region an aperture
% user path encloses. The point's pixel is inset by the fill grid's
% quantum so mere boundary contact stays outside, and insideness is
% any span surviving the intersection. The clip does not participate:
% the test asks about the painting operator's own marks
/.intest {
    4 dict begin
    /.insp exch def
    dup type dup /integertype eq exch /realtype eq or {
        transform
        floor 0.00390625 add /.iny exch def
        floor 0.00390625 add /.inx exch def
        [ [.inx .iny]
          [.inx 0.9921875 add .iny]
          [.inx 0.9921875 add .iny 0.9921875 add]
          [.inx .iny 0.9921875 add] ]
    }{
        gsave newpath uappend flattenpath .fillpolyargs grestore
    } ifelse
    gsave .insp exec exch .clipfillpoly length 2 gt grestore
    end
} bind def

% x y  infill  bool          x y  ineofill  bool
% upath  infill  bool        upath  ineofill  bool
% would fill (eofill) of the current path mark the point's pixel, or
% any of the aperture's region
/infill { { flattenpath .fillpolyargs } .intest } bind def
/ineofill { { closepath flattenpath .fillpolyargs .eospanpoly } .intest } bind def

% the stroke and user-path forms wrap the two above: the subject
% becomes the current path inside a gsave -- the stroke outline fills
% by the nonzero rule -- and the probe operands pass through beneath
/instroke { gsave strokepath infill grestore } bind def
/inufill { gsave newpath uappend infill grestore } bind def
/inueofill { gsave newpath uappend ineofill grestore } bind def
/inustroke { gsave ustrokepath infill grestore } bind def

% x1 y1 x2 y2 rect  .hairsegclip  x1' y1' x2' y2' true
%                                 false
% the portion of the segment within the rectangle [x0 y0 x1 y1],
% found by walking the parameter range against each edge; an
% endpoint on the boundary stays, so a segment ending on a shared
% tile edge still marks the boundary pixel, as the unclipped walk
% would
/.hairsegclip {
    12 dict begin
    aload pop
    /ey exch def
    /ex exch def
    /by exch def /bx exch def
    /qy exch def /qx exch def /py exch def /px exch def
    /dx qx px sub def /dy qy py sub def
    /t0 0 def /t1 1 def /ok true def
    [ [ dx neg px bx sub ] [ dx ex px sub ]
      [ dy neg py by sub ] [ dy ey py sub ] ]
    {
        aload pop /q exch def /p exch def
        p 0 eq {
            q 0 lt { /ok false def } if
        }{
            /r q p div def
            p 0 lt {
                r t1 gt { /ok false def }{ r t0 gt { /t0 r def } if } ifelse
            }{
                r t0 lt { /ok false def }{ r t1 lt { /t1 r def } if } ifelse
            } ifelse
        } ifelse
    } forall
    ok t0 t1 le and {
        px dx t0 mul add py dy t0 mul add
        px dx t1 mul add py dy t1 mul add
        true
    }{ false } ifelse
    end
} bind def

% x1 y1 x2 y2  .hairext  x1' y1' x2' y2'
% lengthen the segment by the stored half-width at each end: the cap
% of a stroke within a pixel's width, round and projecting alike
/.hairext {
    userdict /.hairhw get dup 0 le { pop }{
        8 dict begin
        /hw exch def
        {/y2 /x2 /y1 /x1}{exch def}forall
        /dx x2 x1 sub def
        /dy y2 y1 sub def
        /len dx dup mul dy dup mul add sqrt def
        len 0 gt {
            /ux dx len div hw mul def
            /uy dy len div hw mul def
            x1 ux sub y1 uy sub x2 ux add y2 uy add
        }{
            x1 y1 x2 y2
        } ifelse
        end
    } ifelse
} def

% -  stroke  -
% draw line along current path
% A device with a StrokePath method consumes the whole path itself
% (vector devices stroke with true joins, caps and width); raster
% devices take the hairline DrawLine walk when the device-space width
% is within a pixel, else the stroked outline is filled.
/stroke {
    .patternactive {
        strokepath .patternfill
    }{
    DEVICE /StrokePath known {
        % dashing and non-rectangular clipping consume line segments;
        % with neither active the path passes through unflattened, so
        % curves reach the device
        currentdash pop length 0 eq .cliptrivial and not {
            flattenpath
            dashpath
            doclip
        } if
        [ currentcolordict DEVICE /nativecolorspace get get exec
        .applytransfer
        DEVICE dup /StrokePath get exec
        pop
        flushpage
        newpath
    }{
    % the hairline walk clips each segment against the rectangular
    % clip region before plotting it: a complex clip takes the outline
    % fill below, whose span intersection is exact for any region
    currentlinewidth 0 dtransform
    dup mul exch dup mul exch add sqrt
    % a butt cap adds nothing; round and projecting reach half the
    % width past each segment end
    userdict /.hairhw
    2 index 2 div currentlinecap 0 eq { pop 0 } if put
    1 le
    .cliprect { 4 array astore }{ null } ifelse
    userdict /.hairrect 3 -1 roll put
    userdict /.hairrect get null ne and {
        flattenpath
        dashpath
        mark
        {          % x0 y0
            2 copy % x0 y0 x0 y0
            %pstack(M)=
        }
        {          % ... xN-1 yN-1 xN yN
            4 copy % ... xN-1 yN-1 xN yN xN-1 yN-1 xN yN
            .hairext
            userdict /.hairrect get .hairsegclip {
                [ currentcolordict DEVICE /nativecolorspace get get exec
                .applytransfer
                counttomark 5 add -4 roll
                %5 1 roll  % ... xN-1 yN-1 xN yN gray xN-1 yN-1 xN yN
                %pstack(L)=
                DEVICE dup /DrawLine get exec  % ... xN-1 yN-1 xN yN
                pop
            } if
            4 2 roll pop pop % ... xN yN
        }
        {}
        {            % x0 y0 xN yN
            4 2 roll % xN yN x0 y0
            .hairext
            userdict /.hairrect get .hairsegclip {
                [ currentcolordict DEVICE /nativecolorspace get get exec
                .applytransfer
                counttomark 5 add -4 roll
                %5 1 roll % gray xN yN x0 y0
                %pstack(C)=
                DEVICE dup /DrawLine get exec  % -
                pop
            } if
        }
        .devpathforall
        cleartomark
        flushpage
    }{
        strokepath
        //fill exec
    } ifelse

    newpath
    } ifelse
    } ifelse
} bind def

% Row machinery: image data arrives from datasrc in arbitrary
% chunks; .fill assembles exact raw rows and .rownorm unpacks a
% row's samples to one byte per sample. Samples pack high-order
% first within each byte, and every row of samples begins on a byte
% boundary (PLRM 4.10), so a sub-byte depth unpacks per row and the
% pad bits fall off with the row's tail. Both run inside a
% dictionary holding datasrc, pend, rawrow, buf, bits and
% rowsamples; rows keep the raster within the string size limit
% however large the image.

% -  .fill  -
% assemble the next raw row into rawrow from the source's chunks,
% carrying any surplus in pend; a dry source leaves the tail zeroed
/.fill {
    /got 0 def
    {
        got rawrow length ge { exit } if
        pend length 0 eq { /pend datasrc def } if
        pend length 0 eq {
            got 1 rawrow length 1 sub { rawrow exch 0 put } for
            exit
        } if
        /take pend length rawrow length got sub
              2 copy gt { exch } if pop def
        rawrow got pend 0 take getinterval putinterval
        /pend pend take pend length take sub getinterval def
        /got got take add def
    } loop
} def

% -  .rownorm  -
% unpack rawrow's rowsamples samples at depth bits into buf, one
% byte per sample: sub-byte depths spread to the byte range, twelve
% bits keep their high byte
/.rownorm {
    bits 8 eq {
        buf 0 rawrow putinterval
    }{ bits 1 eq {
        0 1 rowsamples 1 sub { /s exch def
            buf s
            rawrow s 8 idiv get 7 s 7 and sub neg bitshift 1 and 255 mul
            put
        } for
    }{ bits 2 eq {
        0 1 rowsamples 1 sub { /s exch def
            buf s
            rawrow s 4 idiv get 3 s 3 and sub 2 mul neg bitshift 3 and 85 mul
            put
        } for
    }{ bits 4 eq {
        0 1 rowsamples 1 sub { /s exch def
            buf s
            rawrow s 2 idiv get s 1 and 0 eq { -4 bitshift }{ 15 and } ifelse
            17 mul
            put
        } for
    }{
        % twelve bits: an even sample owns a byte and the next
        % nibble, an odd one the low nibble and the next byte
        0 1 rowsamples 1 sub { /s exch def
            /k s 3 mul 2 idiv def
            buf s
            s 1 and 0 eq {
                rawrow k get
            }{
                rawrow k get 15 and 4 bitshift
                rawrow k 1 add get -4 bitshift or
            } ifelse
            put
        } for
    } ifelse } ifelse } ifelse } ifelse
} def

% src  .imgsource  proc
% normalize an image data source: a file becomes a chunk-reading
% procedure, a string a procedure delivering it, a procedure passes
% through unchanged
/.imgsource {
    dup type /arraytype eq 1 index xcheck not and {
        % a literal array carries one source per component
        [ exch { .imgsource } forall ]
    }{
    dup type /filetype eq {
        [ exch 4096 string /readstring cvx /pop cvx ] cvx
    }{
        dup type /stringtype eq {
            [ exch ] cvx
        } if
    } ifelse } ifelse
} def

% -  .clipspans  array
% the clip region resolved to rectangle spans, as flat device-space
% quads (x0 y0 x1 y1 each): the region path -- a stored user path or
% already-resolved spans -- runs through the fill machinery's
% scan-conversion either way
/.clipspans {
    gsave
    clippath flattenpath
    % resolve by the nonzero rule: the region may hold overlapping
    % subpaths (a stencil's adjacent runs under magnification), which
    % the even-odd resolver would cancel; intersecting with the page
    % rectangle scan-converts the region as the fills themselves do
    .fillpolyargs
    [ [0 0]
      [DEVICE /dimensions get 0 get 0]
      [DEVICE /dimensions get 0 get DEVICE /dimensions get 1 get]
      [0 DEVICE /dimensions get 1 get] ]
    .clipfillpoly
    grestore
    6 dict begin
    /q exch def
    [
    /i 0 def
    {
        i q length ge { exit } if
        /mnx 9e99 def /mny 9e99 def /mxx -9e99 def /mxy -9e99 def
        /got false def
        {
            i q length ge { exit } if
            q i get dup type /nulltype eq { pop /i i 1 add def exit } if
            aload pop
            dup mny lt { dup /mny exch def } if
            dup mxy gt { dup /mxy exch def } if
            pop
            dup mnx lt { dup /mnx exch def } if
            dup mxx gt { dup /mxx exch def } if
            pop
            /got true def
            /i i 1 add def
        } loop
        got { mnx mny mxx mxy } if
    } loop
    ]
    end
} def

% v  .c255  byte
% clamp a 0..1 component and scale it to a byte
/.c255 {
    dup 0 lt { pop 0 } if dup 1 gt { pop 1 } if
    255 mul round cvi
} def

% c  .sampleat  value
% one normalized component of the pixel in hand, from its plane's
% row buffer or the interleaved one
/.sampleat {
    multi { bufs exch get x get }{ base add buf exch get } ifelse
} def

% width height bits mat datasrc decode ncomp mbits mranges  .imagepaintm  -
% the shared image painter: the collectors normalize every sample
% depth to one byte, so each pixel reads ncomp bytes, maps each
% through its Decode range, and delivers the components to setcolor
% in the current colour space. Two masking controls, null when
% unused: mbits is a string of one bit per pixel in byte-padded row
% order (a set bit leaves the pixel unpainted), and mranges an array
% of min,max pairs of normalized sample values (a pixel whose every
% raw component falls within its pair is left unpainted)
/.imagepaintm {
    gsave
        newpath
        24 dict begin
        .refreshscreencell
        {mranges mbits ncomp decode datasrc mat bits height width}{exch def}forall
        % the dictionary image form leaves its Interpolate request in
        % userdict for this one painting; anything else paints stepped
        /interp userdict /.imginterp 2 copy known { get }{ pop pop false } ifelse def
        userdict /.imginterp false put

        % a literal array of sources delivers each component from its
        % own plane; a single source interleaves them. The source is
        % loaded through the dictionary, never by name: an executable
        % array is a procedure and a bare lookup would run it.
        /multi currentdict /datasrc get
               dup type /arraytype eq exch xcheck not and def
        multi {
            /rowsamples width def
            /prb width bits mul 7 add 8 idiv def
            /srcs currentdict /datasrc get def
            /rawrows [ ncomp { prb string } repeat ] def
            /bufs [ ncomp { width string } repeat ] def
            /pends [ ncomp { () } repeat ] def
        }{
            /rowsamples width ncomp mul def
            /rawrow rowsamples bits mul 7 add 8 idiv string def
            /buf rowsamples string def
            /pend () def
        } ifelse
        /mrow width 7 add 8 idiv def

        % a device that consumes whole images -- the vector writers --
        % takes the sample rows and the image-to-device matrix and
        % paints nothing here; the masked forms keep the painting path
        DEVICE /PaintImage known
        mbits null eq and mranges null eq and {
            /m mat matrix invertmatrix matrix currentmatrix
               matrix concatmatrix def
            /allrows height array def
            0 1 height 1 sub { /y exch def
                multi {
                    0 1 ncomp 1 sub { /c exch def
                        /datasrc srcs c get def
                        /pend pends c get def
                        /rawrow rawrows c get def
                        /buf bufs c get def
                        .fill .rownorm
                        pends c pend put
                    } for
                    /irow width ncomp mul string def
                    0 1 width 1 sub { /x exch def
                        0 1 ncomp 1 sub { /c exch def
                            irow x ncomp mul c add
                            bufs c get x get put
                        } for
                    } for
                    allrows y irow put
                }{
                    .fill .rownorm
                    allrows y buf dup length string copy put
                } ifelse
            } for
            width height ncomp m allrows decode interp
            DEVICE dup /PaintImage get exec
        }{

        % per-component decode as base + sample x scale over 0..255
        /dbase ncomp array def
        /dscale ncomp array def
        0 1 ncomp 1 sub { /c exch def
            /dmin decode c 2 mul get def
            dbase c dmin put
            dscale c decode c 2 mul 1 add get dmin sub 255 div put
        } for

        % direct raster path: an axis-aligned mapping, a rectangular
        % clip region and a raster device with a page buffer let each
        % row write straight into the raster through .blitrow, the
        % colour pipeline baked into tables up front: a one-component
        % space bakes decode, colour conversion and transfer into one
        % table by running each of its 256 samples through the
        % interpreter's own machinery; RGB and CMYK samples take
        % per-component decode tables, convert in the operator and
        % pass through the transfer table after
        /blitok false def
        DEVICE /ImgData known {
            DEVICE /nativecolorspace get
            dup /DeviceRGB eq exch /DeviceGray eq or {
                /m mat matrix invertmatrix matrix currentmatrix
                   matrix concatmatrix def
                m 1 get abs 0.000001 lt m 2 get abs 0.000001 lt and {
                    /cspansv null def
                    .cliprect {
                        /ccy1 exch def /ccx1 exch def
                        /ccy0 exch def /ccx0 exch def
                    }{
                        % a non-rectangular region: its resolved spans
                        % clamp each raster write instead
                        /ccx0 0 def /ccy0 0 def
                        /ccx1 DEVICE /dimensions get 0 get def
                        /ccy1 DEVICE /dimensions get 1 get def
                        /cspansv .clipspans def
                    } ifelse
                    /csname currentcolorspace
                        dup type /arraytype eq { 0 get } if def
                    ncomp 1 eq
                    ncomp 3 eq csname /DeviceRGB eq and or
                    ncomp 4 eq csname /DeviceCMYK eq and or
                    { /blitok true def } if
                } if
            } if
        } if
        blitok {
            /nat DEVICE /nativecolorspace get /DeviceRGB eq { 3 }{ 1 } ifelse def
            /tlut 256 string def
            0 1 255 { /v exch def
                tlut v
                v 255 div currenttransfer exec .c255
                put
            } for
            nat 3 eq {
                /tlutr 256 string def
                /tlutg 256 string def
                /tlutb 256 string def
                0 1 255 { /v exch def
                    tlutr v v 255 div
                        graphicsdict /currgstate get /redtransfer get exec
                        .c255 put
                    tlutg v v 255 div
                        graphicsdict /currgstate get /greentransfer get exec
                        .c255 put
                    tlutb v v 255 div
                        graphicsdict /currgstate get /bluetransfer get exec
                        .c255 put
                } for
            } if
            ncomp 1 eq {
                /lut 256 nat mul string def
                0 1 255 { /v exch def
                    v dscale 0 get mul dbase 0 get add setcolor
                    currentcolordict DEVICE /nativecolorspace get get exec
                    nat 3 eq {
                        /bb exch def /gg exch def /rr exch def
                        lut v 3 mul       tlutr rr .c255 get put
                        lut v 3 mul 1 add tlutg gg .c255 get put
                        lut v 3 mul 2 add tlutb bb .c255 get put
                    }{
                        lut v 3 -1 roll .c255 tlut exch get put
                    } ifelse
                } for
            }{
                /dluts [ ncomp { 256 string } repeat ] def
                0 1 ncomp 1 sub { /c exch def
                    /dl dluts c get def
                    0 1 255 { /v exch def
                        dl v
                        v dscale c get mul dbase c get add .c255
                        put
                    } for
                } for
            } ifelse
            /bd 24 dict def
            bd /rows DEVICE /ImgData get put
            bd /devw DEVICE /dimensions get 0 get put
            bd /devh DEVICE /dimensions get 1 get put
            bd /nat nat put
            bd /packed nat 3 eq put
            bd /w width put
            bd /ncomp ncomp put
            multi { bd /bufs bufs put }{ bd /buf buf put } ifelse
            bd /xoff m 4 get put
            bd /xscale m 0 get put
            bd /yoff m 5 get put
            bd /yscale m 3 get put
            bd /cx0 ccx0 put
            bd /cy0 ccy0 put
            bd /cx1 ccx1 put
            bd /cy1 ccy1 put
            cspansv null ne { bd /cspans cspansv put } if
            bd /mbits currentdict /mbits get put
            bd /mrowb mrow put
            bd /mranges currentdict /mranges get put
            bd /cmyk ncomp 4 eq put
            ncomp 1 eq {
                bd /lut lut put
            }{
                bd /dluts dluts put
            } ifelse
            bd /tlut tlut put
            DEVICE /.htcell known {
                bd /.htcell DEVICE /.htcell get put
                bd /.htw DEVICE /.htw get put
                bd /.hth DEVICE /.hth get put
            } if
            nat 3 eq {
                bd /tlutr tlutr put
                bd /tlutg tlutg put
                bd /tlutb tlutb put
            } if
            bd /y 0 put
            /interpok interp def
            interpok {
                bd /interp true put
                multi {
                    /pbufs [ ncomp { width string } repeat ] def
                    bd /prevs pbufs put
                }{
                    /pbuf rowsamples string def
                    bd /prev pbuf put
                } ifelse
                % keep this row's samples for the next call's blend
                /.keeprow {
                    multi {
                        0 1 ncomp 1 sub { /c exch def
                            pbufs c get 0 bufs c get putinterval
                        } for
                    }{
                        pbuf 0 buf putinterval
                    } ifelse
                } def
            } if
            0 1 height 1 sub { /y exch def
                multi {
                    0 1 ncomp 1 sub { /c exch def
                        /datasrc srcs c get def
                        /pend pends c get def
                        /rawrow rawrows c get def
                        /buf bufs c get def
                        .fill .rownorm
                        pends c pend put
                    } for
                }{
                    .fill .rownorm
                } ifelse
                bd /y y put
                interpok {
                    y 0 eq { .keeprow } if
                    bd /last y height 1 sub eq put
                } if
                bd .blitrow
                interpok { .keeprow } if
            } for
        }{
        % invert into a fresh matrix: the operand matrix belongs to
        % the caller, who may reuse it (a Type 3 font mutating one
        % shared matrix per glyph is the classic case)
        mat matrix invertmatrix concat
        0 1 height 1 sub { /y exch def
            multi {
                0 1 ncomp 1 sub { /c exch def
                    /datasrc srcs c get def
                    /pend pends c get def
                    /rawrow rawrows c get def
                    /buf bufs c get def
                    .fill .rownorm
                    pends c pend put
                } for
            }{
                .fill .rownorm
            } ifelse
            0 1 width 1 sub { /x exch def
                /base x ncomp mul def
                /paintit true def
                mbits null ne {
                    mbits y mrow mul x 8 idiv add get
                    7 x 7 and sub neg bitshift 1 and 1 eq
                    { /paintit false def } if
                } if
                paintit mranges null ne and {
                    /inrange true def
                    0 1 ncomp 1 sub { /c exch def
                        c .sampleat
                        dup mranges c 2 mul get lt
                        exch mranges c 2 mul 1 add get gt or
                        { /inrange false def } if
                    } for
                    inrange { /paintit false def } if
                } if
                paintit {
                    0 1 ncomp 1 sub { /c exch def
                        c .sampleat dscale c get mul dbase c get add
                    } for
                    setcolor
                    x y 1 1 rectfill
                } if
            } for
        } for
        } ifelse
        } ifelse

        end
    grestore
} def

/.imagepaint {
    null null .imagepaintm
} def

% raw bits  .mcscale  normalized
% scale a raw sample value as the collectors scale samples to bytes
/.mcscale {
    dup 12 eq { pop -4 bitshift }{
    dup 8 eq { pop }{
    dup 4 eq { pop 17 mul }{
    2 eq { 85 mul }{ 255 mul } ifelse } ifelse } ifelse } ifelse
} def

% imagedict  .imagetype4  -
% colour-key masking: a pixel whose every raw component falls within
% the MaskColor ranges leaves the page untouched. MaskColor holds one
% value per component (an exact colour) or min,max pairs.
/.imagetype4 {
    6 dict begin
    /d exch def
    d /Interpolate 2 copy known { get }{ pop pop false } ifelse
    dup type /booleantype eq { userdict /.imginterp 3 -1 roll put }{ pop } ifelse
    /itbits d /BitsPerComponent get def
    /itn .ncomponents def
    /itrange [
        d /MaskColor get length itn eq {
            d /MaskColor get { itbits .mcscale dup } forall
        }{
            d /MaskColor get { itbits .mcscale } forall
        } ifelse
    ] def
    d /Width get d /Height get itbits d /ImageMatrix get
    d /DataSource get .imgsource
    d /Decode get
    itn null itrange
    end
    .imagepaintm
} def

% imagedict  .imagetype3  -
% explicit masking: MaskDict describes a one-bit-deep stencil over
% the same image space as DataDict's samples; a mask value decoding
% to 1 leaves the pixel unpainted. The three interleaves place the
% mask sample-by-sample in the one stream (1, at the image depth),
% row-by-row in the one stream (2), or in MaskDict's own DataSource
% (3), where the mask's grid may differ from the image's.
/.it1row { % statedict  .it1row  datarow
    begin
    .fill .rownorm
    0 1 iw 1 sub { /i exch def
        /mv buf i nc 1 add mul get def
        iminv { /mv 255 mv sub def } if
        mv 127 gt {
            imbits iy imrow mul i 8 idiv add 2 copy get
            128 i 7 and neg bitshift or put
        } if
        drow i nc mul buf i nc 1 add mul 1 add nc getinterval putinterval
    } for
    /iy iy 1 add def
    drow
    end
} def

/.it2row { % statedict  .it2row  datarow
    begin
    /rawrow mraw def .fill
    iminv {
        0 1 mraw length 1 sub { /k exch def
            imbits iy imrow mul k add mraw k get 255 xor put
        } for
    }{
        imbits iy imrow mul mraw putinterval
    } ifelse
    /rawrow draw def .fill
    /iy iy 1 add def
    draw
    end
} def

/.imagetype3 {
    20 dict begin
    /d exch def
    /md d /MaskDict get def
    /dd d /DataDict get def
    dd /Interpolate 2 copy known { get }{ pop pop false } ifelse
    dup type /booleantype eq { userdict /.imginterp 3 -1 roll put }{ pop } ifelse
    /il d /InterleaveType get def
    /w dd /Width get def
    /h dd /Height get def
    /bpc dd /BitsPerComponent get def
    /n .ncomponents def
    /mw md /Width get def
    /mh md /Height get def
    /minv md /Decode 2 copy known { get }{ pop pop [0 1] } ifelse
           0 get 1 eq def
    /mrow w 7 add 8 idiv def
    /mbits mrow h mul string def
    il 1 eq {
        % one stream, a mask sample at the image depth before each
        % pixel's components: a row procedure de-interleaves as the
        % painter pulls, filing each mask row and yielding the data
        % row normalized (the painter reads it at eight bits)
        /st 16 dict def
        st begin
            /datasrc dd /DataSource get .imgsource def
            /pend () def
            /bits bpc def
            /rowsamples w n 1 add mul def
            /rawrow rowsamples bpc mul 7 add 8 idiv string def
            /buf rowsamples string def
            /drow w n mul string def
            /iw w def /nc n def /imrow mrow def
            /imbits mbits def /iminv minv def
            /iy 0 def
        end
        w h 8 dd /ImageMatrix get
        [ st /.it1row cvx ] cvx
        dd /Decode get n
        mbits null
    }{ il 2 eq {
        % one stream, a byte-aligned one-bit mask row before each
        % byte-aligned image row: the row procedure files the mask
        % row and yields the raw image row
        /st 12 dict def
        st begin
            /datasrc dd /DataSource get .imgsource def
            /pend () def
            /mraw mrow string def
            /draw w n mul bpc mul 7 add 8 idiv string def
            /imrow mrow def
            /imbits mbits def /iminv minv def
            /iy 0 def
        end
        w h bpc dd /ImageMatrix get
        [ st /.it2row cvx ] cvx
        dd /Decode get n
        mbits null
    }{
        % separate streams: read the whole one-bit mask up front,
        % then map its grid over the image's when the two differ
        /mrb mw 7 add 8 idiv def
        /mall mrb mh mul string def
        /datasrc md /DataSource get .imgsource def
        /pend () def
        /rawrow mrb string def
        0 1 mh 1 sub { /my exch def
            .fill
            mall my mrb mul rawrow putinterval
        } for
        mw w eq mh h eq and {
            minv {
                0 1 mall length 1 sub { /k exch def
                    mbits k mall k get 255 xor put
                } for
            }{
                mbits 0 mall putinterval
            } ifelse
        }{
            0 1 h 1 sub { /y exch def
                /sy y mh mul h idiv def
                0 1 w 1 sub { /x exch def
                    /sx x mw mul w idiv def
                    mall sy mrb mul sx 8 idiv add get
                    7 sx 7 and sub neg bitshift 1 and 1 eq
                    minv { not } if {
                        mbits y mrow mul x 8 idiv add 2 copy get
                        128 x 7 and neg bitshift or put
                    } if
                } for
            } for
        } ifelse
        w h bpc dd /ImageMatrix get
        dd /DataSource get .imgsource
        dd /Decode get n
        mbits null
    } ifelse } ifelse
    end
    .imagepaintm
} def

% width height bits/sample matrix datasrc  image  -
%                                imagedict  image  -
% The five-operand form paints grey samples; the dictionary forms
% paint samples in the colour space current when image is invoked:
% ImageType 1 plainly, 3 under an explicit mask, 4 under colour-key
% masking
/image {
    dup type /dicttype eq {
        dup /ImageType get
        dup 1 eq {
            pop
            begin
            currentdict /Interpolate 2 copy known { get }{ pop pop false } ifelse
            dup type /booleantype eq { userdict /.imginterp 3 -1 roll put }{ pop } ifelse
            Width Height BitsPerComponent ImageMatrix
            % fetch through the dictionary: a procedure source fetched
            % by name would execute instead of arriving as the operand
            currentdict /DataSource get .imgsource
            Decode
            end
            .ncomponents .imagepaint
        }{ dup 3 eq {
            pop .imagetype3
        }{ 4 eq {
            .imagetype4
        }{
            pop /image cvx /rangecheck signalerror
        } ifelse } ifelse } ifelse
    }{
        gsave
        /DeviceGray setcolorspace
        .imgsource [ 0 1 ] 1 .imagepaint
        grestore
    } ifelse
} def

% width height bits matrix datasrc false ncomp  colorimage  -
% paint interleaved samples in the device space matching the
% component count: one grey, three RGB or four CMYK components per
% pixel through the shared painter, in its own colour space like the
% five-operand image. One data source per component (multi true) is
% unsupported and refused.
/.identdecode <<
    1 [ 0 1 ]
    3 [ 0 1 0 1 0 1 ]
    4 [ 0 1 0 1 0 1 0 1 ]
>> def
/colorimage {
    4 dict begin
    /nc exch def
    /msrc exch def
    nc //.identdecode exch known not {
        end /colorimage cvx /rangecheck signalerror
    } if
    msrc {
        % gather the per-component sources into one literal array
        /srcs nc array def
        nc 1 sub -1 0 { srcs exch 3 -1 roll .imgsource put } for
    }{
        /srcs exch .imgsource def
    } ifelse
    gsave
    nc 4 eq { /DeviceCMYK }{
    nc 3 eq { /DeviceRGB }{ /DeviceGray } ifelse } ifelse
    setcolorspace
    % the source loads through the dictionary, never by name: an
    % executable array is a procedure and a bare lookup would run it,
    % leaving its first chunk standing in for the whole image
    currentdict /srcs get //.identdecode nc get nc
    end
    null null .imagepaintm
    grestore
} def

% width height polarity matrix datasrc interp  .stencilmask  -
% paint the current colour through a one-bit stencil: samples equal to
% the polarity mark unit squares of image space, the rest leave the
% page untouched. Each row of samples begins on a byte boundary.
% the runs of small stencils, resolved once per distinct mask: text
% shown through Type 3 bitmap fonts paints the same few masks over
% and over, and scanning their bits again for every occurrence is
% where such jobs spend their time. Keyed by a content hash, verified
% against the stored copy of the mask; runs of consecutive rows
% sharing one extent merge into taller rectangles, whose union is the
% very region the row runs cover
/.stencilcache 64 dict def

% buf width height ink  .stencilruns  rects
/.stencilruns {
    10 dict begin
    /kink exch def /kh exch def /kw exch def /kbuf exch def
    /hh kw 31 mul kh add 33 mul kink add def
    0 1 kbuf length 1 sub {
        kbuf exch get hh 33 mul add 16#FFFFFF and /hh exch def
    } for
    /found null def
    .stencilcache hh 2 copy known {
        get {
            dup 0 get kw eq 1 index 1 get kh eq and
            1 index 2 get kink eq and {
                dup 3 get kbuf eq {
                    4 get /found exch def exit
                } if
            } if
            pop
        } forall
    }{ pop pop } ifelse
    found null ne {
        found
    }{
        /rowbytes kw 7 add 8 idiv def
        /cap kw 2 idiv 1 add kh mul def
        /rxa cap array def /rya cap array def
        /rwa cap array def /rha cap array def
        /rn 0 def
        /prev 0 dict def
        0 1 kh 1 sub { /y exch def
            /cur 8 dict def
            /x 0 def
            {
                x kw ge { exit } if
                kbuf y rowbytes mul x 8 idiv add get
                x 8 mod 7 sub bitshift 1 and kink eq {
                    /x0 x def
                    {
                        /x x 1 add def
                        x kw ge { exit } if
                        kbuf y rowbytes mul x 8 idiv add get
                        x 8 mod 7 sub bitshift 1 and kink ne { exit } if
                    } loop
                    /rl x x0 sub def
                    /ext false def
                    prev x0 2 copy known {
                        get dup rwa exch get rl eq {
                            dup rha exch 2 copy get 1 add put
                            cur x0 3 -1 roll put
                            /ext true def
                        }{ pop } ifelse
                    }{ pop pop } ifelse
                    ext not {
                        rxa rn x0 put rya rn y put
                        rwa rn rl put rha rn 1 put
                        cur x0 rn put
                        /rn rn 1 add def
                    } if
                }{
                    /x x 1 add def
                } ifelse
            } loop
            /prev cur def
        } for
        /rects rn 4 mul array def
        0 1 rn 1 sub { /i exch def
            rects i 4 mul       rxa i get put
            rects i 4 mul 1 add rya i get put
            rects i 4 mul 2 add rwa i get put
            rects i 4 mul 3 add rha i get put
        } for
        .stencilcache length 200 ge { /.stencilcache 64 dict store } if
        /tuple [ kw kh kink kbuf dup length string copy rects ] def
        .stencilcache hh 2 copy known {
            get [ exch aload pop tuple ]
        }{
            pop pop [ tuple ]
        } ifelse
        .stencilcache hh 3 -1 roll put
        rects
    } ifelse
    end
} def

/.stencilmask {
    gsave
        newpath
        10 dict begin
        {interp datasrc mat polarity height width}{exch def}forall
        /rowbytes width 7 add 8 idiv def
        /buf rowbytes height mul string def
        /bp 0 def
        { % collect the sample data
            bp buf length ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            dup length bp add buf length gt {
                0 buf length bp sub getinterval
            } if
            buf exch bp exch
            dup length bp add /bp exch def
            putinterval
        } loop
        % invert into a fresh matrix: the operand matrix belongs to
        % the caller, who may reuse it (a Type 3 font mutating one
        % shared matrix per glyph is the classic case)
        mat matrix invertmatrix concat
        /ink polarity {1}{0} ifelse def
        % consecutive set samples paint as one run; under a pattern
        % colour the runs assemble into a single path so the tiling
        % runs once over the whole stencil
        /paintpat .patternactive def
        % a glyph-context stencil blends its edges when the device
        % blends text, the transform is axis-aligned, and nothing
        % clips: the coverage painter writes pixels directly
        /aadone false def
        paintpat not
        graphicsdict /.inglyph 2 copy known { get }{ pop pop false } ifelse
        interp or and
        .cliptrivial and {
            << /buf buf /width width /height height
               /ink ink /interp interp
               /mat matrix currentmatrix >> .stencilaa
            { /aadone true def } if
        } if
        aadone not {
        width height mul 16384 le {
            /rects buf width height ink .stencilruns def
            paintpat { newpath } if
            0 4 rects length 1 sub { /i exch def
                rects i get rects i 1 add get
                rects i 2 add get rects i 3 add get
                paintpat {
                    /rh exch def /rw exch def /ry exch def /rx exch def
                    rx ry moveto rx rw add ry lineto
                    rx rw add ry rh add lineto rx ry rh add lineto closepath
                }{
                    rectfill
                } ifelse
            } for
            paintpat { .patternfill } if
        }{
        paintpat { newpath } if
        0 1 height 1 sub { /y exch def
            /x 0 def
            {
                x width ge { exit } if
                buf y rowbytes mul x 8 idiv add get
                x 8 mod 7 sub bitshift 1 and ink eq {
                    /x0 x def
                    {
                        /x x 1 add def
                        x width ge { exit } if
                        buf y rowbytes mul x 8 idiv add get
                        x 8 mod 7 sub bitshift 1 and ink ne { exit } if
                    } loop
                    paintpat {
                        x0 y moveto x y lineto
                        x y 1 add lineto x0 y 1 add lineto closepath
                    }{
                        x0 y x x0 sub 1 rectfill
                    } ifelse
                }{
                    /x x 1 add def
                } ifelse
            } loop
        } for
        paintpat { .patternfill } if
        } ifelse
        } if
        end
    grestore
} def

% width height polarity matrix datasrc  imagemask  -
%                                  maskdict  imagemask  -
% The dictionary form (ImageType 1) states its polarity through
% Decode: [1 0] paints where the sample is one, as operand polarity
% true does; [0 1] paints the zeroes
/imagemask {
    dup type /dicttype eq {
        begin
        ImageType 1 ne { end /imagemask cvx /rangecheck signalerror } if
        Width Height
        Decode 0 get 0 ne
        ImageMatrix
        % fetch through the dictionary: a procedure source fetched by
        % name would execute instead of arriving as the operand
        currentdict /DataSource get .imgsource
        currentdict /Interpolate 2 copy known { get }{ pop pop false } ifelse
        dup type /booleantype ne { pop false } if
        end
    }{
        .imgsource false
    } ifelse
    .stencilmask
} def

/QUIET where { pop }{ (eof paint.ps\n)print } ifelse
