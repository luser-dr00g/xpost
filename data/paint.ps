/QUIET where { pop }{ (loading paint.ps...)print } ifelse

% Painting Operators

% -  erasepage  -
% paint current page white
/erasepage {
    % a device with an Erase method resets the page itself (the alpha
    % device clears to transparent); otherwise paint the page white
    DEVICE /Erase known {
        DEVICE dup /Erase get exec
        flushpage
    }{
    gsave
        1 setgray
        [ currentcolordict DEVICE /nativecolorspace get
        get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        0 0 DEVICE /dimensions get aload pop
        DEVICE dup /FillRect get exec
        pop
        flushpage
    grestore
    } ifelse
} bind def

% -  fill  -
% fill current path with current color
% A device with a FillPath method consumes the whole path itself
% (vector devices fill with curves preserved). The path must lie
% inside a rectangular clip: a non-trivial clip region is cut by the
% polygon machinery below, at the cost of flattening.
/fill {
    closepath
    DEVICE /FillPath known .cliptrivial and {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        DEVICE dup /FillPath get exec
        pop
        flushpage
        newpath
    }{
    flattenpath
    doclip
    % subpaths merged into one point list, separated by null, so that
    % FillPoly scans them together and interior subpaths produce holes
    .fillpolyargs
    /DEBUGFILL where { pop
        (fill)=
        pstack()=
        hook
    } if

    dup length 2 gt {
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        counttomark 2 add -1 roll
        DEVICE dup /FillPoly get exec
        pop
        %pstack()=
    }{
        pop
    } ifelse

    flushpage
    newpath
    } ifelse
} bind def

% -  eofill  -
% fill using even-odd rule
% Approximated by the nonzero fill: the two rules differ only for
% self-overlapping or same-wound-hole paths, which the fill pipeline
% here does not distinguish
/eofill {
    fill
} def

% -  stroke  -
% draw line along current path
% A device with a StrokePath method consumes the whole path itself
% (vector devices stroke with true joins, caps and width); raster
% devices take the hairline DrawLine walk when the device-space width
% is within a pixel, else the stroked outline is filled.
/stroke {
    DEVICE /StrokePath known {
        % dashing and non-rectangular clipping consume line segments;
        % with neither active the path passes through unflattened, so
        % curves reach the device
        currentdash pop length 0 eq .cliptrivial and not {
            flattenpath
            dashpath
            doclip
        } if
        [ currentcolordict DEVICE /nativecolorspace get get exec
        counttomark { currenttransfer exec counttomark 1 roll } repeat
        DEVICE dup /StrokePath get exec
        pop
        flushpage
        newpath
    }{
    currentlinewidth 0 dtransform
    dup mul exch dup mul exch add sqrt
        1 le {
        flattenpath
        dashpath
        doclip
        mark
        {          % x0 y0 
            2 copy % x0 y0 x0 y0
            %pstack(M)=
        }
        {          % ... xN-1 yN-1 xN yN
            4 copy % ... xN-1 yN-1 xN yN xN-1 yN-1 xN yN
            [ currentcolordict DEVICE /nativecolorspace get get exec
            counttomark { currenttransfer exec counttomark 1 roll } repeat
            counttomark 5 add -4 roll
            %5 1 roll  % ... xN-1 yN-1 xN yN gray xN-1 yN-1 xN yN
            %pstack(L)=
            DEVICE dup /DrawLine get exec  % ... xN-1 yN-1 xN yN
            pop
            4 2 roll pop pop % ... xN yN
        }
        {}
        {            % x0 y0 xN yN
            4 2 roll % xN yN x0 y0
            [ currentcolordict DEVICE /nativecolorspace get get exec
            counttomark { currenttransfer exec counttomark 1 roll } repeat
            counttomark 5 add -4 roll
            %5 1 roll % gray xN yN x0 y0
            %pstack(C)=
            DEVICE dup /DrawLine get exec  % -
            pop
        }
        .devpathforall
        cleartomark
        flushpage
    }{
        strokepath
        fill
    } ifelse

    newpath
    } ifelse
} bind def

/bitsdict <<
    1 {
        {
            bp bz ge {exit} if
            datasrc % src
            { % char
                8 {
                    dup % char char
                    -1 bitshift exch % char>1 char
                    1 and % char>1 c0
                    255 mul % char>1 c0'
                    buf exch bp exch put /bp bp 1 add def
                } repeat
                pop
            } forall
        } loop
    }
    2 {
        {
            bp bz ge {exit} if
            datasrc % src
            { % char

                4 {
                    dup % char char
                    -2 bitshift exch % char>2 char
                    3 and % char>2 c01
                    85 mul  % char>2 c01'
                    buf exch bp exch put /bp bp 1 add def
                } repeat

                %dup % char>2 char>2
                %-2 bitshift exch % char>4 char>2
                %3 and % char>4 c23
                %85 mul  % char>4 c23'
                %buf exch bp exch put /bp bp 1 add def

                %dup % char>4 char>4
                %-2 bitshift exch % char>6 char>4
                %3 and % char>6 c45
                %85 mul  % char>6 c45'
                %buf exch bp exch put /bp bp 1 add def

                %dup % char>6 char>6
                %-2 bitshift exch % char>8 c67
                %85 mul
                %buf exch bp exch put /bp bp 1 add def

                pop

            } forall
        } loop
    }
    4 {
        {
            bp bz ge {exit} if
            datasrc % str
            { % char
                0 exch dup % 0 char char

                2 {
                    15 and % char  lo
                    17 mul % char lo'
                    buf exch bp exch put /bp bp 1 add def
                    -4 bitshift % hi
                } repeat % 0

                pop

            } forall
        } loop
    }
    8 {
        {
            bp bz ge {exit} if
            datasrc
            buf exch bp exch
            dup length
            %pstack()=
            bp add /bp exch def
            putinterval
        } loop
    }
    12 {
    }
>> def

% width height bits/sample matrix datasrc  image  -
/image {
    %pstack()=
    gsave
        newpath
        10 dict begin
        {datasrc mat bits height width}{exch def}forall

        /vdx 1 width div def
        /vdy 1 height div def
        /DeviceGray setcolorspace
        /bz width height mul def
        /buf bz string def
        /bp 0 def

        bitsdict bits get exec

        mat mat invertmatrix concat
        %vdx vdy scale
        0 1 height 1 sub { /y exch def
            0 1 width 1 sub { /x exch def
                buf y width mul x add get 255 div
                setcolor
                x %vdx mul
                y %vdy mul %mat itransform
                1 1 %vdx vdy %mat idtransform
                %pstack()=
                rectfill
            } for
        } for

        end
    grestore
} def

% width height polarity matrix datasrc  imagemask  -
% paint the current colour through a one-bit stencil: samples equal to
% the polarity mark unit squares of image space, the rest leave the
% page untouched. Each row of samples begins on a byte boundary.
/imagemask {
    gsave
        newpath
        10 dict begin
        {datasrc mat polarity height width}{exch def}forall
        /rowbytes width 7 add 8 idiv def
        /buf rowbytes height mul string def
        /bp 0 def
        { % collect the sample data
            bp buf length ge {exit} if
            datasrc
            dup length 0 eq {pop exit} if
            dup length bp add buf length gt {
                0 buf length bp sub getinterval
            } if
            buf exch bp exch
            dup length bp add /bp exch def
            putinterval
        } loop
        mat mat invertmatrix concat
        /ink polarity {1}{0} ifelse def
        0 1 height 1 sub { /y exch def
            0 1 width 1 sub { /x exch def
                buf y rowbytes mul x 8 idiv add get
                x 8 mod 7 sub bitshift 1 and
                ink eq {
                    x y 1 1 rectfill
                } if
            } for
        } for
        end
    grestore
} def

/QUIET where { pop }{ (eof paint.ps\n)print } ifelse
