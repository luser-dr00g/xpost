%init.ps is run before systemdict is made readonly
%
%systemdict /ud userdict put %trigger backup error handler

%procedures in systemdict
/QUIET where { pop }{ (loading init.ps...\n) print } ifelse

%(35\n) print
%currentfile flushfile

systemdict begin % make these definitions in systemdict
true setglobal   % systemdict is global, so these allocations must be global

/statusdict <<
    /manualfeed false
    /product (Xpost)
>> def

% the page-size convenience operators of the printer products, which
% driver prologs invoke from their PPD feature blocks
<<
    /letter      [ 612  792]
    /lettersmall [ 612  792]
    /note        [ 612  792]
    /legal       [ 612 1008]
    /ledger      [1224  792]
    /11x17       [ 792 1224]
    /a3          [ 842 1191]
    /a4          [ 595  842]
    /a4small     [ 595  842]
    /a5          [ 420  595]
    /b4          [ 728 1032]
    /b5          [ 516  729]
>> {
    1 dict dup /PageSize 4 -1 roll put
    /setpagedevice cvx 2 array astore cvx def
} forall

% the job server's dictionary. exitserver ends the encapsulated job,
% announces that permanent state may change, and execution continues
% with the definitions made so far outliving the job -- the idiom
% every driver prolog uses. xpost runs jobs unencapsulated, so
% announcing and unwinding the begun dictionary is the whole of it.
/serverdict 2 dict def
serverdict /exitserver {
    pop
    (%%[ exitserver: permanent state may be changed ]%%\n) print flush
    currentdict serverdict eq { end } if
} put

% bool password  startjob  bool
% job boundaries are accepted -- definitions persist either way,
% as xpost runs jobs unencapsulated
/startjob { pop pop true } def

% the interpreter answers for the whole language
/languagelevel 3 def

/setvmthreshold { pop } def

% the shared-VM view of global VM, one and the same here
/setshared /setglobal load def
/currentshared /currentglobal load def
/scheck /gcheck load def
/shareddict globaldict def

/strcat {
    2 copy
    length exch length exch 1 index add % a b an bn+an
    string dup 0 6 -1 roll putinterval % b an str
    dup 4 2 roll exch putinterval % (ab)
} bind def

%% predefined in xpost_interpreter.c:setlocalconfig()
%%
%/DATA_DIR 
%    /PACKAGE_DATA_DIR dup where { %PACKAGE_DATA_DIR is passed from the config if is_installed is true
%        exch get
%    }{
%        pop
%        %EXE_DIR (/../../data) strcat
%        %(./data)  % if is_installed is false, and no PACKAGE_DATA_DIR is defined, look for ps data in CWD/data
%        false mark [
%            /WIN32 where { pop
%                (../../../data) %visual_studio/vc10/Debug
%            } if
%            (data) %repo root
%            (../../data) %src/bin
%            (../../../data) %visual_studio/vc10/Debug
%        ]
%        {
%            {
%                dup (/err.ps) strcat (r) file % false mark ... (DIR) file
%                pop counttomark 2 add 1 roll cleartomark pop true mark % (DIR) true mark
%            } stopped not { exit } if
%        } forall
%        cleartomark
%        not { () } if % none of the above, try CWD
%    } ifelse
%def

%(EXE_DIR =) print EXE_DIR print (\n) print
/QUIET where { pop }{ (DATA_DIR =) print DATA_DIR print (\n) print } ifelse

%(1\n)print
%/product (Xpost) def % now an operator in xpost_op_misc.c
%/version (0) def % now an operator in xpost_op_misc.c
%/revision 0 def % now an operator in xpost_op_misc.c
/run { (r) file cvx exec } def
/Run { (\() print dup =print (\) run\n) print flush run } def
/interrupt { stop } def

%(2\n)print
/=string 128 string def
/=print {
    dup type /stringtype ne {
        //=string cvs
    } if
    print
} bind def
/=only //=print def

%(3\n)print
/= {
    //=print exec
    (\n) print
} bind def

%dumpnames dumpvm
%debugloadon

%(/err.ps)
%(.) [ {
%    (XPOSTDIR) getenv %env
%    exch pop exch pop
%} stopped {cleartomark} if
%exch strcat Run
%(../../data)

%(4\n)print
DATA_DIR
(/err.ps)
strcat
run

%(5\n)print
/stack { count dup 1 add copy //= repeat pop } def

%(6\n)print
userdict begin
% ==
24 dict begin
/==dict currentdict def
    /rmargin 72 def
    /NL (\n) def

    /cvsprint {
        =string cvs tprint
        ( ) tprint
    } def
    /tprint {
        dup length cp add rmargin gt {
            NL print
            /cp 0 def
        } if
        dup length cp add /cp exch def
        print
    } def
    /typeprint { dup type exec } def

    /arraytype {
        dup rcheck {
            dup xcheck {
                ({ ) tprint { typeprint } forall (} ) tprint
            }{
                ([ ) tprint { typeprint } forall (] ) tprint
            } ifelse
        }{ pop (-array-) tprint } ifelse
    } def
    { cvsprint }
    dup /booleantype exch def
    dup /integertype exch def
    /realtype exch def

    /invalidtype { pop (@INVALID@) tprint } def
    /nulltype { pop (null ) tprint } def
    /dicttype { pop (-dict- ) tprint } def
    /filetype { pop (-file- ) tprint } def
    /marktype { pop (-mark- ) tprint } def
    /fonttype { pop (-font- ) tprint } def
    /contexttype { pop (-context- ) tprint } def

    /nametype {
        dup xcheck not {
            (/) tprint
        } if
        cvsprint
    } def

    /operatortype {
        (--) tprint
        =string cvs tprint
        (--) tprint
    } def

    /savetype {
        pop (-savelevel- ) tprint
    } def

    /stringtype {
        dup rcheck {
            (\() tprint tprint (\)) tprint
        }{
            pop (-string- ) tprint
        } ifelse
    } def

/==only {
    %traceon
    //==dict begin
        /cp 0 def
        { typeprint } stopped
    end            % pop ==dict whether typeprint succeeded or errored,
    { stop } if    % so an error inside == does not strand it on the
                   % dict stack; re-raise once the dict stack is clean
} end def % remove ==dict, installing == in userdict
/== { ==only (\n) print } def
/pstack { count dup 1 add copy //== repeat pop } def
end % back to systemdict


/execdict 6 dict def
execdict begin
    /quitflag false def
    /checkquit {
        //execdict /quitflag get
        { exit } if
    } def
    /execdepth 0 def
end

% initiate an interactive session with prompt
% a postscript 'executive' session
/start {
    currentglobal
    false setglobal
    {
        loadgraphics
    } stopped {
        (unable to load graphics)print
        handleerror
        pstack
        quit
    } if
    % shadow the `quit` operator with this procedure which checks
    % the depth of 'executive' nesting
    userdict /quit {
        %exit
        //execdict /quitflag true put
        $error /newerror false put
        interrupt
    } put
    setglobal

    /executive load stopped
    pop //quit % the operator
} def

% execute postscript program from stdin, and handle errors,
% but do not assume an interactive session
/startstdin {
    {
        loadgraphics
    } stopped {
        (unable to load graphics)print
        quit
    } if
    {
        (%stdin) run
    } stopped {
        handleerror
    } if
    quit
} def

% execute postscript program from a named file, and handle errors.
/startfilename { % (filename)
    /inputfilename exch def
    {
        loadgraphics
    } stopped {
        (unable to load graphics)print
        quit
    } if
    {
        inputfilename (r) file cvx exec
        executive
    } stopped {
        handleerror
    } if
    quit
} def
%currentfile flushfile

% execute a postscript program from a file object, which may represent
% a stream with no associated "name".
/startfile { % file-object
    /QUIET where { pop }{ (startfile\n)print } ifelse
    /inputfile exch def
    {
        loadgraphics
    } stopped {
        (unable to load graphics)print
        quit
    } if
    {
        inputfile cvx exec
    } stopped {
        .rundied
        handleerror
    } if
    quit
} def

/prompt {
    (PS) print
    count dup 0 eq { pop } { (<) print //=print exec } ifelse
    //execdict /execdepth get {
        (>) print
    } repeat
    flush
} def

/setdevparams {
} def
/currentdevparams {
} def
/setuserparams {
} def
/currentuserparams {
} def
/setsystemparams {
} def
/currentsystemparams {
} def



end % systemdict

userdict begin
false setglobal

/executive {
    //execdict begin

    /execdepth execdepth 1 add def
    /QUIET where { pop }{
        product print
        ( version ) print version print
        (.) print revision =print
        (\n) print
    } ifelse

    { %loop
        /quitflag false def
        //$error /newerror false put
        /prompt load stopped {
            (Error during prompt execution\n) print
            handleerror
            exit
        } if
        {
            mark
            /stmtfile (%statementedit) (r) file def
        } stopped {
            cleartomark
            //$error /newerror get {
                //$error /errorname get 
                /undefinedfilename ne { % ^d at prompt
                    handleerror
                } if
                //$error /newerror false put
                exit
            } if
        }{
            pop stmtfile end
            {
                cvx exec
            } stopped //execdict begin {
                handleerror
                stmtfile closefile
            } if
        } ifelse
        checkquit
    } loop
    /quitflag false def
    //execdict /execdepth 2 copy get 1 sub put

    end
    //$error /doclose false put
    interrupt
} bind
def


DATA_DIR (/qsort.ps) strcat
run

% (s1) (s2) (s3) ... (sN) n  ncat  (s1s2s3...sN)
/ncat {        % s1 s2 s3 .. sN n
    dup 1 add  % s1 s2 s3 .. sN n n+1 
    copy       % s1 s2 s3 .. sN n  s1 s2 s3 .. sN n
    0 exch     % s1 s2 s3 .. sN n  s1 s2 s3 .. sN 0 n 
    {   
        exch length add 
    } repeat             % s1 s2 s3 .. sN  n   len 
    string exch          % s1 s2 s3 .. sN str   n   
    0 exch               % s1 s2 s3 .. sN str  off  n
    -1 1 {               % s1 s2 s3 .. sN str  off  n
        2 add -1 roll       % s2 s3 .. sN str  off s1
        3 copy putinterval  % s2 s3 .. sN str' off s1
        length add          % s2 s3 .. sN str' off+len(s1)
                            % s2 s3 .. sN str' off'
    } for                               % str' off'
    pop  % str'
} def 


% Named Resources: the Level 2 resource operators live in their own
% data file
/DIRSEP (/) def
DATA_DIR (/resource.ps) strcat run
DATA_DIR (/cid.ps) strcat run

%traceon
%debugloadon

currentglobal
false setglobal
/fontsubstitutions <<
    /Times-Roman (Nimbus Roman No9 L)
    dup (URW Bookman L)

    /Courier (Liberation Mono)
    dup /FreeMono
    dup (Hershey\\-Plain\\-Triplex)
    dup (DejaVu Sans Mono)

    /Helvetica (DejaVu Sans)
    dup (Nimbus Sans L)

    /Palatino-Roman (URW Palladio L)
>> def

% The FontDirectory holds defined fonts; findfont dictionaries for
% host faces state the type of the program that backs them.
/FontDirectory
<<
>> def
setglobal

end % userdict

/findfont {
    FontDirectory 1 index known {
        FontDirectory exch get
    }{
        {   % try the operator, which states FontType, FontMatrix
            % and FontBBox for the face behind the name
            //findfont
            % a text font's built-in encoding is the standard one; a
            % fresh copy, so a program re-encoding in place cannot
            % touch the shared array. A face without standard glyph
            % names still resolves through its character map.
            dup /Encoding StandardEncoding dup length array copy put
            dup /BuildChar {} put
        } stopped { % operator failed: 
            fontsubstitutions exch 2 copy known { % try substitution
                get
                findfont % call proc (tail-)recursively 
            }{
                exch pop
                (no defined substitute for unfound font)=
                =
            } ifelse
        } if
    } ifelse
} def

% index any  defineuserobject  -
% the user-object table lives in userdict, growing as indices demand
/defineuserobject {
    exch
    dup 0 lt { /defineuserobject cvx /rangecheck signalerror } if
    userdict /UserObjects known not {
        userdict /UserObjects 10 array put
    } if
    dup UserObjects length ge {
        dup 1 add UserObjects length 2 mul 2 copy lt { exch } if pop
        array dup 0 UserObjects putinterval
        userdict /UserObjects 3 -1 roll put
    } if
    UserObjects exch 3 -1 roll put
} def

% index  execuserobject  -
/execuserobject {
    UserObjects exch get exec
} def

% index  undefineuserobject  -
/undefineuserobject {
    UserObjects exch null put
} def

% formdict  execform  -
% paint the form: its matrix maps form space into user space, its
% bounding box clips, and its paint procedure takes the dictionary.
% Every execution paints afresh -- the language permits it
% formdict  .execformdirect  -
% paint the form afresh: its matrix concatenates, its bounding box
% clips, and the paint procedure runs with the dictionary at hand
/.execformdirect {
    gsave
    dup /Matrix get concat
    dup /BBox get aload pop     % form llx lly urx ury
    2 index sub                 % form llx lly urx h
    exch 3 index sub exch       % form llx lly w h
    rectclip
    dup /PaintProc get exec
    grestore
} def

% formdict  .execformbox  bx by w h
% the device pixel box holding the form's bounding box under the
% current transformation and the form's own matrix
/.execformbox {
    8 dict begin
    /fd exch def
    gsave
    fd /Matrix get concat
    /mnx 9e99 def /mny 9e99 def /mxx -9e99 def /mxy -9e99 def
    fd /BBox get aload pop
    /ury exch def /urx exch def /lly exch def /llx exch def
    [ [llx lly] [urx lly] [urx ury] [llx ury] ] {
        aload pop transform
        dup mxy gt { dup /mxy exch def } if
        dup mny lt { dup /mny exch def } if pop
        dup mxx gt { dup /mxx exch def } if
        dup mnx lt { dup /mnx exch def } if pop
    } forall
    grestore
    mnx floor mny floor
    mxx ceiling mnx floor sub cvi
    mxy ceiling mny floor sub cvi
    end
} def

% formdict  execform  -
% Paint a form. On a raster page the output is cached: the paint
% runs once over a black ground and once over white in an offscreen
% raster of the device's own class, pixels that agree are the form's
% own marks -- painting is opaque, so a pixel the paint left alone
% still shows its ground -- and later executions under the same
% linear transformation copy the marks straight onto the page,
% quantized to the pixel grid. Blended glyph edges differ between
% the grounds and stay uncovered, keeping the page's own background
% there. The cache serves within a rectangular clip that holds the
% whole raster; anything else -- a vector or screening device, an
% unwritable dictionary, an oversized raster -- paints afresh. A
% form's own execform calls run inside its capture, so nested forms
% cache independently.
/execform {
    dup type /dicttype ne { /execform cvx /typecheck signalerror } if
    dup /FormType 2 copy known { get 1 eq }{ pop pop false } ifelse
    not { /execform cvx /rangecheck signalerror } if
    DEVICE /ImgData known
    DEVICE /ScreenPaint known not and
    1 index wcheck and
    not {
        .execformdirect
    }{
        20 dict begin
        /fd exch def
        fd /.formid known not {
            userdict /.formserial 2 copy known { get }{ pop pop 1 } ifelse
            fd /.formid 2 index put
            userdict /.formserial 3 -1 roll 1 add put
        } if
        % the key: the form and the transformation's linear part on a
        % thousandth grid; the position quantizes at replay
        /cm matrix currentmatrix def
        /key fd /.formid get 20 string cvs
        [ cm 0 get cm 1 get cm 2 get cm 3 get ] {
            1000 mul round cvi 20 string cvs
            exch (:) strcat exch strcat
        } forall def
        /fc userdict /.formcache 2 copy known { get }{
            pop pop 8 dict userdict /.formcache 2 index put
        } ifelse def
        fd .execformbox
        /fh exch def /fw exch def /fby exch def /fbx exch def
        fc key known not {
            fw 0 gt fh 0 gt and fw fh mul 4194304 le and {
                /rgbdev DEVICE /nativecolorspace get /DeviceRGB eq def
                /mdev fw fh
                    rgbdev { newPPMIMAGEdevice }{ newPGMIMAGEdevice } ifelse
                def
                mdev /FillPoly /.fillpoly load put
                mdev /FillRect
                    rgbdev { /.fillrectrgb }{ /.fillrectgray } ifelse
                    load put
                % blended glyph edges would differ between the two
                % grounds and fall out of the coverage; bilevel text
                % keeps every glyph pixel deterministic
                mdev /TextAlphaBits 1 put
                gsave
                graphicsdict /currgstate get /device mdev put
                /cm2 cm matrix copy def
                cm2 4 cm 4 get fbx sub put
                cm2 5 cm 5 get fby sub put
                cm2 setmatrix
                initclip
                rgbdev { 0 0 0 0 0 fw fh mdev .fillrectrgb }
                       { 0 0 0 fw fh mdev .fillrectgray } ifelse
                fd .execformdirect
                /rowsa [ mdev /ImgData get {
                    dup type /stringtype eq
                        { dup length string copy }
                        { dup length array copy } ifelse
                } forall ] def
                rgbdev { 1 1 1 0 0 fw fh mdev .fillrectrgb }
                       { 1 0 0 fw fh mdev .fillrectgray } ifelse
                fd .execformdirect
                grestore
                fc length 8 ge {
                    userdict /.formcache 8 dict put
                    /fc userdict /.formcache get def
                } if
                fc key <<
                    /rows mdev /ImgData get
                    /mask rowsa mdev /ImgData get .formmask
                >> put
            } if
        } if
        fc key known
        { .cliprect {
              /cy1 exch def /cx1 exch def /cy0 exch def /cx0 exch def
              fbx cx0 ge fby cy0 ge and
              fbx fw add cx1 le and fby fh add cy1 le and
          }{ false } ifelse }
        { false } ifelse
        {
            /fe fc key get def
            fe /rows get fe /mask get fbx fby DEVICE .blitform
        }{
            fd .execformdirect
        } ifelse
        end
    } ifelse
} def

% User paths: the self-describing form is an executable array of the
% path operators below; the encoded form pairs an operand source (a
% number array or encoded number string) with a string of opcodes,
% where an opcode of 32 or more repeats the following operator that
% many fewer than its value times
/setbbox { pop pop pop pop } def    % the box is advisory here
/ucache {} def

/.upathops [ /setbbox /moveto /rmoveto /lineto /rlineto /curveto
             /rcurveto /arc /arcn /arct /closepath /ucache ] def
/.upathargs [ 4 2 2 2 2 6 6 5 5 5 0 0 ] def

% userpath  uappend  -
/uappend {
    dup xcheck {
        exec
    }{
        8 dict begin
        dup 0 get dup type /stringtype eq { .numstring2array } if
        /args exch def
        1 get /ops exch def
        /ai 0 def
        /rep 1 def
        0 1 ops length 1 sub {
            ops exch get
            dup 31 gt {
                32 sub /rep exch def
            }{
                /op exch def
                rep {
                    .upathargs op get { args ai get /ai ai 1 add def } repeat
                    .upathops op get cvx exec
                } repeat
                /rep 1 def
            } ifelse
        } for
        end
    } ifelse
} def

% matrix and user path operands tell apart by shape: a matrix is a
% six-element literal array of numbers
/.isupmat {
    dup type /arraytype eq
    1 index xcheck not and
    1 index length 6 eq and
    { dup 0 get type dup /integertype eq exch /realtype eq or }
    { false } ifelse
} def

/ufill { gsave newpath uappend fill grestore } def
/ueofill { gsave newpath uappend eofill grestore } def
/ustroke {
    .isupmat {
        gsave newpath exch uappend concat stroke grestore
    }{
        gsave newpath uappend stroke grestore
    } ifelse
} def
/ustrokepath {
    .isupmat {
        matrix currentmatrix 3 1 roll
        exch newpath uappend
        concat strokepath
        setmatrix
    }{
        newpath uappend strokepath
    } ifelse
} def

% bool  upath  userpath
% the current path, written as a user path in current user space
/upath {
    [ exch { /ucache cvx } if
      pathbbox /setbbox cvx
      { /moveto cvx }{ /lineto cvx }{ /curveto cvx }{ /closepath cvx }
      pathforall
    ] cvx
} def

% mark key value ... /TYPE  pdfmark  -
% Route document metadata to a device that can carry it (the pdfwrite
% device collects DOCINFO into its trailer); every other mark type,
% and marks on devices without metadata, are consumed without effect.
/pdfmark {
    counttomark 0 gt {
        dup /DOCINFO eq DEVICE /.docinfo known and {
            pop
            counttomark 2 idiv {
                DEVICE /.docinfo get 3 1 roll put
            } repeat
        } if
    } if
    cleartomark
} bind def

%   /fontname size  selectfont  -
% /fontname matrix  selectfont  -
/selectfont {
    dup type /arraytype eq {
        exch findfont
        exch makefont
        setfont
    }{
        exch findfont
        exch scalefont
        setfont
    } ifelse
} def

% x y w h
/rect { %ccw in device space
    dtransform 4 2 roll transform 4 2 roll
    dup 0 gt { neg 3 2 roll 1 index sub 3 1 roll } if
    1 index 0 lt { exch neg 4 3 roll 1 index sub 4 1 roll exch } if
    idtransform 4 2 roll itransform 
    2 copy 6 2 roll
    moveto
    1 index 0 rlineto
    0 exch rlineto
    neg 0 rlineto
    lineto
} def

% the painting pair works on its own path and leaves the caller's
% untouched; rectclip clips by the rectangles alone and clears the
% path, as the language specifies
/rectfill { gsave newpath rect fill grestore } def
/rectstroke { gsave newpath rect stroke grestore } def
/rectclip { newpath rect clip newpath } def

/runtest {
    DATA_DIR (/test.ps) strcat run
} def

% load graphics support
/loadgraphics {
    /GRAPHICS_LOADED where { pop }{
        DATA_DIR (/graphics.ps) strcat run

    % Page device selection and configuration. Keys:
    %   /OutputDevice   name from the device table (defaults to the
    %                   device the interpreter started with)
    %   /PageSize       [w h] points (default 612x792)
    %   /HWResolution   [rx ry] dots per inch (default [72 72])
    %   /OutputFile     output path for the device
    %   /PageOffset     [x y] points, translated after initgraphics
    % Every other key is stored on the device dictionary, which is how
    % device features (TextAlphaBits, WhiteIsOpaque, ...) are reached.
    % Same-device requests merge over the previous ones, so a partial
    % dictionary adjusts the page; switching OutputDevice starts from
    % the new device's defaults. The outgoing device is destroyed
    % (freeing its buffers; a vector device's output was written by
    % showpage's Emit), the new device is installed
    % in the graphics state template, and the page is reinitialised.
    /.devicemakers <<
        /pgm { newPGMIMAGEdevice }
        /pbm { newPBMIMAGEdevice }
        /ppm { newPPMIMAGEdevice }
        /tiff { newTIFFIMAGEdevice }
        /null { newnulldevice }
        /bbox { newbboxdevice }
        /pdfwrite { newPDFWRITEdevice }
        /svgwrite { newSVGWRITEdevice }
        /dscwrite { newDSCWRITEdevice }
        /png { /newpngdevice where { pop }{ loadpngdevice } ifelse newpngdevice }
        /pngalpha { /newpngalphadevice where { pop }{ loadpngalphadevice } ifelse newpngalphadevice }
        /jpeg { /newjpegdevice where { pop }{ loadjpegdevice } ifelse newjpegdevice }
    >> def

    % pagedevicedict  setpagedevice  -
    /setpagedevice {
        dup type /dicttype ne {
            /setpagedevice cvx /typecheck signalerror
        } if
        16 dict begin
        /pd exch def
        % requests merge with the accumulated parameters, except that
        % switching OutputDevice reinstalls the new device's defaults:
        % nothing carries across a device change
        /merged
        pd /OutputDevice 2 copy known {
            get /.pagedevice where {
                pop .pagedevice /OutputDevice 2 copy known
                    { get }{ pop pop null } ifelse
            }{ null } ifelse ne
        }{ pop pop false } ifelse
            { pd length 8 add dict }
            { /.pagedevice where
                { pop .pagedevice dup length pd length add dict copy }
                { pd length 8 add dict }
            ifelse }
        ifelse def
        pd { merged 3 1 roll put } forall
        /dev merged /OutputDevice 2 copy known { get }{ pop pop
            /.outputdevice where { pop .outputdevice }{ /pgm } ifelse
        } ifelse def
        .devicemakers dev known not {
            end /setpagedevice cvx /rangecheck signalerror
        } if
        /res merged /HWResolution 2 copy known { get }{ pop pop [72 72] } ifelse def
        /size merged /PageSize 2 copy known { get }{ pop pop [612 792] } ifelse def
        /off merged /PageOffset 2 copy known { get }{ pop pop [0 0] } ifelse def
        /sx res 0 get 72 div def
        /sy res 1 get 72 div def
        % raster buffers need whole pixels, but the page itself need not
        % be integral: a vector device adopts the exact dimensions (its
        % width and height are points, written into its output syntax)
        /pwf size 0 get sx mul def
        /phf size 1 get sy mul def
        /pw pwf ceiling cvi def
        /ph phf ceiling cvi def

        % device constructors read /OutputFileName via where; the
        % host's binding persists across page device changes, as an
        % output file given on a command line does
        merged /OutputFile 2 copy known {
            get userdict /OutputFileName 3 -1 roll put
        }{ pop pop } ifelse

        % retire the outgoing device (Destroy frees its buffers; a
        % vector device's output was written by showpage's Emit)
        /DEVICE where { pop
            DEVICE type /dicttype eq {
                DEVICE dup /Destroy 2 copy known { get exec }{ pop pop pop } ifelse
            } if
        } if

        userdict /.exactpagedims [pwf phf] put
        userdict /DEVICE pw ph .devicemakers dev get exec put
        userdict /.exactpagedims undef

        % post-construction fixups, as the initial device receives.
        % The flip translate must match the height the device adopted,
        % or marks sit offset within a fractional page.
        DEVICE /defaultmatrix
            [ sx 0 0 sy neg 0 DEVICE /height 2 copy known { get }{ pop pop ph } ifelse ] put
        DEVICE /NoOutput known not {
            DEVICE /FillPoly /.fillpoly load put
            DEVICE /nativecolorspace get /DeviceGray eq {
                DEVICE /FillRect /.fillrectgray load put
            } if
            DEVICE /nativecolorspace get /DeviceRGB eq {
                DEVICE /FillRect get type /operatortype ne {
                    DEVICE /FillRect /.fillrectrgb load put
                } if
            } if
        } if

        % remaining keys are device features
        merged { % key value
            1 index /OutputDevice eq
            2 index /PageSize eq or
            2 index /HWResolution eq or
            2 index /OutputFile eq or
            2 index /PageOffset eq or
            { pop pop }{ DEVICE 3 1 roll put } ifelse
        } forall
        merged /OutputDevice dev put
        userdict /.pagedevice merged put

        % a device declaring support for the requested process colour
        % model adopts it as its native space; the colour pipeline then
        % delivers that model's components to the marking methods
        DEVICE /ProcessColorModel 2 copy known {
            get DEVICE /.colormodels 2 copy known {
                get 1 index known {
                    DEVICE /nativecolorspace 3 -1 roll put
                }{ pop } ifelse
            }{ pop pop pop } ifelse
        }{ pop pop } ifelse

        % the template and the live gstate carry the device; painting
        % and the defaultmatrix operator resolve it through them
        gstatetemplate /device DEVICE put
        graphicsdict /currgstate get /device DEVICE put
        initgraphics
        off aload pop translate
        end
    } def

    % -  currentpagedevice  dict
    /currentpagedevice {
        /.pagedevice where { pop
            .pagedevice dup length 1 add dict copy
        }{
            << /PageSize [ DEVICE /dimensions get aload pop ] >>
        } ifelse
    } def
        userdict /GRAPHICS_LOADED true put
        /QUIET where { pop }{ (graphics loaded, calling initgraphics\n)print } ifelse
        userdict /USEDRAWLINE true put
        initgraphics
    } ifelse
} def

/testfont {
    loadgraphics
    /Courier findfont
    40 scalefont
    setfont
    100 100 moveto
    (Hello World!) show
} def

$error/initializing false put % ready to go!
false setglobal

% debug ps functions
/break{ /hook /pause load def } def
/clearhook{ /hook {} store } def
/doprompt{
    (\nbreak>)print flush
    (%lineedit)(r)file
    cvx {exec}stopped pop } def
/pause{ doprompt } def
/hook{ } def

/.dir {
    (*) { = } 128 string filenameforall
} def

/xpost {
    (Xpost is running. Please type a command:\n)print
    (Would you like to 'runtest' or 'testfont' or '(filename)run'?\n)print
} def

DATA_DIR (/prepr.ps) strcat run  % use nifty preview prompt!

/QUIET where { pop }{ (eof init.ps\n)print } ifelse
%loadgraphics %called by start* procs
