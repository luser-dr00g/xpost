%!
% CID-keyed composite fonts (PLRM 5.11): the CIDInit procedure set
% builds CMap dictionaries, composefont assembles a Type 0 font from
% a CMap and its descendant CIDFonts, and the composite show
% machinery decodes character codes through the CMap to CIDs, maps
% them to glyph indices through the descendant's CIDMap, and paints
% the glyphs by index. A CIDFontType 2 descendant carries a TrueType
% template in /sfnts with its outlines delivered incrementally in
% /GlyphDirectory; the face is assembled (and reassembled as the
% directory grows) by .loadcidfont2.

/QUIET where { pop }{ (loading cid.ps...)print } ifelse

% resource categories for the composite font machinery
[ /CIDFont /CMap /ProcSet ] {
    /c exch def
    c /Category resourcestatus { pop pop }{
        /Generic /Category findresource
        dup length 1 add dict copy
        dup /Category c put
        c exch /Category defineresource pop
    } ifelse
} forall
currentdict /c undef

% The CIDInit procedure set: a program begins a dictionary, invokes
% these operators to accumulate the code spaces and ranges into it,
% and defines the result as a /CMap resource instance. The bracketed
% operand lists arrive on the stack; each end operator gathers them
% into (or appends to) an array in the dictionary under construction.
/CIDInit <<
    % (Binary)|(Hex) length  StartData  -
    % the glyph data block that ends a CIDFont resource file: read it,
    % attach it to the dictionary under construction as /GlyphData,
    % close the dictionary and the procedure set, and define the
    % completed CIDFont resource
    /StartData {
        currentdict /.sdn 3 -1 roll put
        (Hex) eq {
            currentdict /.sdf currentfile /ASCIIHexDecode filter put
            currentdict /.sdhex true put
        }{
            currentdict /.sdf currentfile put
            currentdict /.sdhex false put
        } ifelse
        .sdn 65000 le {
            currentdict /GlyphData .sdf .sdn string readstring pop put
        }{
            currentdict /GlyphData [
                {
                    .sdn 0 le { exit } if
                    .sdf .sdn 65000 min string readstring pop
                    currentdict /.sdn .sdn 65000 sub put
                } loop
            ] put
        } ifelse
        % the in-band terminator of a hex block belongs to it
        .sdhex { .sdf flushfile } if
        currentdict /.sdn undef
        currentdict /.sdf undef
        currentdict /.sdhex undef
        currentdict /CIDFontName get currentdict
        end end
        /CIDFont defineresource pop
    }
    /begincmap {}
    /endcmap {}
    /begincodespacerange { pop mark }
    /endcodespacerange {
        counttomark array astore exch pop
        /.newr exch def
        /.codespaces currentdict /.codespaces known {
            [ .codespaces aload pop .newr aload pop ]
        }{ .newr } ifelse def
    }
    /begincidrange { pop mark }
    /endcidrange {
        counttomark array astore exch pop
        /.newr exch def
        /.cidranges currentdict /.cidranges known {
            [ .cidranges aload pop .newr aload pop ]
        }{ .newr } ifelse def
    }
    /beginnotdefrange { pop mark }
    /endnotdefrange {
        counttomark array astore exch pop
        /.notdefranges exch def
    }
    /begincidchar { pop mark }
    /endcidchar {
        counttomark array astore exch pop
        /.newr exch def
        /.cidchars currentdict /.cidchars known {
            [ .cidchars aload pop .newr aload pop ]
        }{ .newr } ifelse def
    }
    % single-descendant jobs select font 0; the association of later
    % ranges with other descendants is not kept
    /usefont { pop }
    /usecmap { pop }
    % base-font character mappings (ToUnicode tables) pass through
    % this procedure set too: accept and discard them
    /beginbfchar { pop mark }
    /endbfchar { cleartomark }
    /beginbfrange { pop mark }
    /endbfrange { cleartomark }
    /beginrearrangedfont { pop pop mark }
    /endrearrangedfont { cleartomark }
>> /ProcSet defineresource pop

%   key cmap fonts  composefont  font
% assemble a Type 0 composite font: names resolve through their
% resource categories, the CMap decodes the codes, the descendants
% carry the glyphs
/composefont {
    dup type /arraytype ne { /composefont cvx /typecheck signalerror } if
    [ exch { dup type /nametype eq { /CIDFont findresource } if } forall ]
    exch dup type /nametype eq { /CMap findresource } if
    exch
    8 dict begin
    /FDepVector exch def
    /CMap exch def
    /FontType 0 def
    /FMapType 9 def
    /FontMatrix matrix def
    /Encoding [ 0 ] def
    /WMode CMap /WMode 2 copy known { get }{ pop pop 0 } ifelse def
    currentdict end
    definefont
} def

% str pos cmapdict  .cmapnext  cid nbytes
% decode one character code: the code space whose byte width brackets
% the bytes at pos names the width, the cid ranges (and single-cid
% assignments) supply the CID; an unmapped code is CID 0
/.cmapnext {
    20 dict begin
    /cm exch def /p exch def /s exch def
    /cs cm /.codespaces 2 copy known { get }{ pop pop [ <00> <FF> ] } ifelse def
    /w 1 def
    /code s p get def
    /matched false def
    0 2 cs length 2 sub { /k exch def
        matched not {
            /lo cs k get def
            /hi cs k 1 add get def
            /wl lo length def
            p wl add s length le {
                /c 0 def /clo 0 def /chi 0 def
                0 1 wl 1 sub { /b exch def
                    /c c 256 mul s p b add get add def
                    /clo clo 256 mul lo b get add def
                    /chi chi 256 mul hi b get add def
                } for
                c clo ge c chi le and {
                    /matched true def /w wl def /code c def
                } if
            } if
        } if
    } for
    /cid 0 def
    /rgs cm /.cidranges 2 copy known { get }{ pop pop [] } ifelse def
    0 3 rgs length 3 sub { /k exch def
        rgs k get length w eq {
            /rlo 0 def /rhi 0 def
            0 1 w 1 sub { /b exch def
                /rlo rlo 256 mul rgs k get b get add def
                /rhi rhi 256 mul rgs k 1 add get b get add def
            } for
            code rlo ge code rhi le and {
                /cid rgs k 2 add get code rlo sub add def
            } if
        } if
    } for
    /rgs cm /.cidchars 2 copy known { get }{ pop pop [] } ifelse def
    0 2 rgs length 2 sub { /k exch def
        rgs k get length w eq {
            /rlo 0 def
            0 1 w 1 sub { /b exch def
                /rlo rlo 256 mul rgs k get b get add def
            } for
            code rlo eq { /cid rgs k 1 add get def } if
        } if
    } for
    cid w
    end
} def

% ciddict  .cidface  -
% assemble (or reassemble) the descendant's face around the glyphs
% delivered so far: the directory flattens into a glyph-indexed
% array for the synthesizer, and the count is remembered so a grown
% directory triggers a rebuild
/.cidface {
    4 dict begin
    /d exch def
    /gd d /GlyphDirectory 2 copy known { get }{ pop pop 0 dict } ifelse def
    gd length 0 eq {
        % no incremental glyphs: the template is the whole program
        d .loadfont42
    }{
        /mx 0 def
        gd { pop dup mx gt { /mx exch def }{ pop } ifelse } forall
        /ga mx 1 add array def
        gd { ga 3 1 roll put } forall
        d ga .loadcidfont2
    } ifelse
    d /.gdcount gd length put
    end
} def

% str p fnt fidx0  .fmapnext  fidx code w
% decode one character of a byte-mapped composite font: the font
% selector, the code for the selected font, and the bytes consumed.
% 8/8 splits two bytes, 1/7 and 9/7 split the top bit or nine of a
% one- or two-byte code, and the SubsVector mapping walks its ranges
% -- the leading byte gives the code width less one, each following
% width-sized big-endian entry one range -- subtracting until the
% code falls within one. The modal mappings thread their selection:
% fidx0 is the selector in force, escape sequences (doubled under a
% double-escape mapping to reach past 255) and shift bytes replace
% it and belong to the code that follows, and a string ending inside
% a prefix answers a code of -1, which paints nothing. Bytes past
% the string's end read as zero
/.fmapnext {
    12 dict begin
    /fidx exch def /fnt exch def /p exch def /str exch def
    /p0 p def
    /nb { % i . byte  (zero past the end)
        dup str length lt { str exch get }{ pop 0 } ifelse
    } def
    /fm fnt /FMapType get def
    /code -1 def
    fm 2 eq {
        /fidx p nb def
        /code p 1 add nb def
        /p p 2 add def
    }{ fm 4 eq {
        /fidx p nb -7 bitshift def
        /code p nb 127 and def
        /p p 1 add def
    }{ fm 5 eq {
        /fidx p nb 1 bitshift p 1 add nb -7 bitshift add def
        /code p 1 add nb 127 and def
        /p p 2 add def
    }{ fm 6 eq {
        /sv fnt /SubsVector get def
        /wd sv 0 get 1 add def
        /nr sv length 1 sub wd idiv def
        /t 0 def
        0 1 wd 1 sub { p add nb t 256 mul add /t exch def } for
        /fidx 0 def
        {
            fidx nr ge { exit } if
            /rs 0 def
            0 1 wd 1 sub { fidx wd mul add 1 add sv exch get
                          rs 256 mul add /rs exch def } for
            t rs lt { exit } if
            /t t rs sub def
            /fidx fidx 1 add def
        } loop
        /code t def
        /p p wd add def
    }{ fm 3 eq fm 7 eq or {
        /esc fnt /EscChar 2 copy known { get }{ pop pop 255 } ifelse def
        {
            p str length ge { exit } if
            p nb esc ne {
                /code p nb def
                /p p 1 add def
                exit
            } if
            /fidx p 1 add nb def
            /p p 2 add def
            fm 7 eq fidx esc eq and {
                /fidx p nb 256 add def
                /p p 1 add def
            } if
        } loop
    }{ fm 8 eq {
        /si fnt /ShiftIn 2 copy known { get }{ pop pop 15 } ifelse def
        /so fnt /ShiftOut 2 copy known { get }{ pop pop 14 } ifelse def
        {
            p str length ge { exit } if
            p nb si eq { /fidx 0 def /p p 1 add def }{
            p nb so eq { /fidx 1 def /p p 1 add def }{
                /code p nb def
                /p p 1 add def
                exit
            } ifelse } ifelse
        } loop
    }{
        /show cvx /rangecheck signalerror
    } ifelse } ifelse } ifelse } ifelse } ifelse } ifelse
    fidx code p p0 sub
    end
} def

% fnt fidx  .fmapdesc  font'
% the descendant the font selector names through Encoding, with its
% matrix carried through the composite's
/.fmapdesc {
    3 dict begin
    /fidx exch def /fnt exch def
    /desc fnt /FDepVector get fnt /Encoding get fidx get get def
    desc dup length dict copy
    dup /FontMatrix desc /FontMatrix get
        fnt /FontMatrix get matrix concatmatrix put
    end
} def

% fnt str  .showfmap  -
% paint a string through a byte-mapped composite font: each decoded
% code paints as a one-byte show under the selected descendant, so
% any descendant kind -- including a nested composite -- renders
% through the ordinary dispatch
% code  .showhook  -
% called after each composite character paints, with the character's
% full (multi-byte, big-endian) code. The spacing show operators bind
% it to advance the pen by their delta; plain show leaves it a no-op.
/.showhook { pop } def

/.showfmap {
    12 dict begin
    /str exch def /fnt exch def
    /dc fnt /Encoding get length array def
    /cs 1 string def
    /p 0 def
    /curf 0 def
    {
        p str length ge { exit } if
        str p fnt curf .fmapnext
        /w exch def /code exch def /curf exch def
        code 0 ge {
            dc curf get null eq {
                dc curf fnt curf .fmapdesc put
            } if
            cs 0 code put
            graphicsdict /currgstate get /currfont dc curf get put
            cs show
            graphicsdict /currgstate get /currfont fnt put
            /fc 0 def
            0 1 w 1 sub { str p 3 -1 roll add get fc 256 mul add /fc exch def } for
            fc .showhook
        } if
        /p p w add def
    } loop
    end
} def

% font str  .showtype0  -
% paint a string through a composite font: a CMap-mapped font (the
% FMapType 9 of composefont) decodes each code to a CID, the CID
% maps to a glyph index through the descendant's CIDMap (GDBytes
% bytes per entry, across the array of segments), and the glyph
% paints by index under the descendant's face carried through the
% composite's matrix; the byte-mapped FMapTypes decode and dispatch
% per descendant instead
/.showtype0 {
    1 index /FMapType get 9 ne {
        .showfmap
    }{
    20 dict begin
    /str exch def
    /fnt exch def
    /cm fnt /CMap get def
    /desc fnt /FDepVector get 0 get def
    % a CIDFontType 2 descendant renders through an assembled face,
    % rebuilt when its glyph directory has grown since
    desc /CIDFontType 2 copy known { get 2 eq }{ pop pop false } ifelse {
        desc /GlyphDirectory 2 copy known { get length }{ pop pop 0 } ifelse
        desc /.gdcount 2 copy known { get }{ pop pop -1 } ifelse
        ne { desc .cidface } if
    } if
    % a CIDFontType 0 descendant carries its charstrings in the
    % GlyphData block; the face assembles once and serves by CID
    desc /CIDFontType 2 copy known { get 0 eq }{ pop pop false } ifelse
    desc /GlyphData known and
    desc /Private known not and {
        desc .loadcidfont0
    } if
    /wrap desc dup length 2 add dict copy def
    wrap /FontMatrix
        desc /FontMatrix 2 copy known { get }{ pop pop matrix } ifelse
        fnt /FontMatrix get matrix concatmatrix put
    /gdb desc /GDBytes 2 copy known { get }{ pop pop 1 } ifelse def
    /cidmap desc /CIDMap 2 copy known { get }{ pop pop null } ifelse def
    graphicsdict /currgstate get /currfont wrap put
    /p 0 def
    {
        p str length ge { exit } if
        str p cm .cmapnext
        /w exch def
        /cid exch def
        /gid cid def
        cidmap null ne {
            /off cid gdb mul def
            /gid 0 def
            cidmap type /stringtype eq {
                off gdb add cidmap length le {
                    0 1 gdb 1 sub { /b exch def
                        /gid gid 256 mul cidmap off b add get add def
                    } for
                } if
            }{
                /seg 0 def
                {
                    seg cidmap length ge { exit } if
                    off cidmap seg get length lt { exit } if
                    /off off cidmap seg get length sub def
                    /seg seg 1 add def
                } loop
                seg cidmap length lt {
                    off gdb add cidmap seg get length le {
                        0 1 gdb 1 sub { /b exch def
                            /gid gid 256 mul cidmap seg get off b add get add def
                        } for
                    } if
                } if
            } ifelse
        } if
        gid .glyphshowidx
        /fc 0 def
        0 1 w 1 sub { str p 3 -1 roll add get fc 256 mul add /fc exch def } for
        fc .showhook
        /p p w add def
    } loop
    graphicsdict /currgstate get /currfont fnt put
    end
    } ifelse
} def

% a one-byte identity CMap: cshow's procedure sees the descendant
% under byte codes, the idiom drivers use to repaint one glyph at a
% time from inside the procedure
/.bytecmap <<
    /.codespaces [ <00> <FF> ]
    /.cidranges [ <00> <FF> 0 ]
>> def

%   proc string  cshow  -
% call the procedure for each character with its code and width,
% painting nothing itself. Through a composite font the codes decode
% by the CMap first, and while the procedure runs the current font
% is the composite rebound to one-byte codes, so a show of the
% code's byte inside the procedure paints the glyph the code named.
/cshow {
    graphicsdict /currgstate get /currfont get
    dup /FontType get 0 eq {
    dup /FMapType get 9 ne {
        % a byte-mapped composite: the procedure runs with the
        % selected descendant current, as the mapping chose it
        20 dict begin
        /fnt exch def /str exch def /proc exch def
        /dc fnt /Encoding get length array def
        /p 0 def
        /curf 0 def
        {
            p str length ge { exit } if
            str p fnt curf .fmapnext
            /w exch def /code exch def /curf exch def
            code 0 ge {
                dc curf get null eq {
                    dc curf fnt curf .fmapdesc put
                } if
                /cs 1 string dup 0 code put def
                gsave
                    nulldevice
                    graphicsdict /currgstate get /currfont dc curf get put
                    0 0 moveto cs show currentpoint
                grestore
                /wy exch def /wx exch def
                graphicsdict /currgstate get /currfont dc curf get put
                code wx wy proc
                graphicsdict /currgstate get /currfont fnt put
            } if
            /p p w add def
        } loop
        end
    }{
        20 dict begin
        /fnt exch def /str exch def /proc exch def
        /cm fnt /CMap get def
        /bw fnt dup length 1 add dict copy def
        bw /CMap //.bytecmap put
        /p 0 def
        {
            p str length ge { exit } if
            str p cm .cmapnext
            /w exch def /cid exch def
            /cs 1 string dup 0 cid 255 and put def
            gsave
                nulldevice
                graphicsdict /currgstate get /currfont bw put
                0 0 moveto cs show currentpoint
            grestore
            /wy exch def /wx exch def
            graphicsdict /currgstate get /currfont bw put
            cid wx wy proc
            graphicsdict /currgstate get /currfont fnt put
            /p p w add def
        } loop
        end
    } ifelse
    }{
        20 dict begin
        /fnt exch def /str exch def /proc exch def
        /p 0 def
        {
            p str length ge { exit } if
            /cs str p 1 getinterval def
            gsave
                nulldevice
                0 0 moveto cs show currentpoint
            grestore
            /wy exch def /wx exch def
            cs 0 get wx wy proc
            /p p 1 add def
        } loop
        end
    } ifelse
} def

/QUIET where { pop }{ (eof cid.ps\n)print } ifelse
