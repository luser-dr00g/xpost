/QUIET where { pop }{ (loading color.ps...)print } ifelse


/setcolorspace {
    %[ currentcolor setcolordict currentcolorspace get counttomark 2 add -1 roll
    % record the space as set (what currentcolorspace reports), then the
    % space the colour components are recorded in: a Separation or
    % DeviceN colour is converted on setcolor, so its components live in
    % the alternative space
    graphicsdict /currgstate get 1 index /setspace exch put
    dup type /arraytype eq { dup 0 get dup /Separation eq exch /DeviceN eq or } { false } ifelse {
        2 get
    } if
    graphicsdict /currgstate get exch /colorspace exch put
    graphicsdict /currgstate get /colorcomp1 0.0 put
    graphicsdict /currgstate get /colorcomp2 0.0 put
    graphicsdict /currgstate get /colorcomp3 0.0 put
    graphicsdict /currgstate get /colorcomp4 0.0 put
    graphicsdict /currgstate get /sepindex null put
    %exec pop
} bind def

/currentcolorspace {
    graphicsdict /currgstate get /setspace get
} bind def

/setcolordict <<
    /DeviceGray /setgray cvx
    /DeviceRGB /setrgbcolor cvx
    /DeviceCMYK /setcmykcolor cvx
    /Pattern { pop }
>> def
/setcolor {
    currentcolorspace
    dup type /arraytype eq { dup 0 get dup /Separation eq exch /DeviceN eq or } { false } ifelse
    {
        % [/Separation name alt tint] or [/DeviceN names alt tint]:
        % switch to the alternative space and convert via the tint
        % transform. setcolor must not change what currentcolorspace
        % reports, so stash the space being painted in and restore it
        % after the conversion (whose device-space setters overwrite it)
        dup graphicsdict exch /.sepspace exch put
        dup 0 get /Separation eq { DEVICE /.registersep known } { false } ifelse {
            % a device that preserves separations also receives the
            % (tint, space) pair: convert first (the device-space
            % setters clear the gstate's separation record), then
            % register with the device and record its index and the
            % tint for the marking methods
            2 copy dup 2 get setcolorspace 3 get exec setcolor
            1 index exch                       % tint tint space
            DEVICE dup /.registersep get exec  % tint index true | tint false
            {
                graphicsdict /currgstate get exch /sepindex exch put
                graphicsdict /currgstate get exch /septint exch put
            }{
                pop
            } ifelse
        }{
            dup 2 get setcolorspace
            3 get exec
            setcolor
        } ifelse
        graphicsdict /currgstate get /setspace graphicsdict /.sepspace get put
    } {
        //setcolordict exch get exec
    } ifelse
} bind def

/currentcolordict <<
    /DeviceGray /currentgray cvx
    /DeviceRGB /currentrgbcolor cvx
    /DeviceCMYK /currentcmykcolor cvx
    % a device with the /Process native space takes each paint in the
    % space it was set in: deliver the current colour unconverted (one
    % grey component, three RGB or four CMYK)
    /Process /currentcolor cvx
>> def
/currentcolor {
    % deliver the recorded components: keyed by the space they are
    % recorded in (for Separation/DeviceN, the alternative space)
    //currentcolordict graphicsdict /currgstate get /colorspace get get exec
} bind def

/.min { % x y  . x (if x < y)
        %        y (otherwise)
    2 copy gt{exch}if pop
} bind def

/ColorConversion << % <</dest <</source {source-to-dest conversion}>> >>
    /DeviceGray <<
        /DeviceGray {
            graphicsdict /currgstate get /colorcomp1 get
        } bind
        /DeviceRGB {
            graphicsdict /currgstate get /colorcomp1 get
            .3 mul
            graphicsdict /currgstate get /colorcomp2 get
            .59 mul add
            graphicsdict /currgstate get /colorcomp3 get
            .11 mul add
        } bind
        /DeviceCMYK {
            1
            graphicsdict /currgstate get /colorcomp1 get
            .3 mul
            graphicsdict /currgstate get /colorcomp2 get
            .59 mul add
            graphicsdict /currgstate get /colorcomp3 get
            .11 mul add
            graphicsdict /currgstate get /colorcomp4 get
            add
            1 .min sub
        } bind
    >>
    /DeviceRGB <<
        /DeviceGray {
            graphicsdict /currgstate get /colorcomp1 get
            dup
            dup
        } bind
        /DeviceRGB {
            graphicsdict /currgstate get /colorcomp1 get
            graphicsdict /currgstate get /colorcomp2 get
            graphicsdict /currgstate get /colorcomp3 get
        } bind
        /DeviceCMYK {
            graphicsdict /currgstate get /colorcomp4 get % k
            1 graphicsdict /currgstate get /colorcomp1 get % k 1 c
            2 index add 1 .min sub % k 1-min(1,c+k)
            1 graphicsdict /currgstate get /colorcomp2 get % k R 1 m
            3 index add 1 .min sub % k R 1-min(1,m+k)
            1 graphicsdict /currgstate get /colorcomp3 get % k R G 1 y
            5 4 roll add 1 .min sub % R G 1-min(1,y+k)
        } bind
    >>
    /DeviceCMYK <<
        /DeviceGray {
            0
            0
            0
            1 graphicsdict /currgstate get /colorcomp1 get sub
        } bind
        /DeviceRGB {
            % full black generation and undercolor removal: the common
            % component moves entirely into the black channel, so black
            % separates as pure K rather than four inks
            1 graphicsdict /currgstate get /colorcomp1 get sub
            1 graphicsdict /currgstate get /colorcomp2 get sub .min
            1 graphicsdict /currgstate get /colorcomp3 get sub .min  % k
            dup dup dup                                              % k k k k
            1 graphicsdict /currgstate get /colorcomp1 get sub exch sub % k k k c'
            4 1 roll                                                 % c' k k k
            1 graphicsdict /currgstate get /colorcomp2 get sub exch sub % c' k k m'
            3 1 roll                                                 % c' m' k k
            1 graphicsdict /currgstate get /colorcomp3 get sub exch sub % c' m' k y'
            exch                                                     % c' m' y' k
        } bind
        /DeviceCMYK {
            graphicsdict /currgstate get /colorcomp1 get
            graphicsdict /currgstate get /colorcomp2 get
            graphicsdict /currgstate get /colorcomp3 get
            graphicsdict /currgstate get /colorcomp4 get
        } bind
    >>
>> def

/setgray {
    graphicsdict /currgstate get /setspace /DeviceGray put
    graphicsdict /currgstate get /colorspace /DeviceGray put
    graphicsdict /currgstate get exch /colorcomp1 exch put
    graphicsdict /currgstate get /sepindex null put
} bind def

/currentgray {
    ColorConversion /DeviceGray get
        graphicsdict /currgstate get /colorspace get
        get exec
} bind def

/setrgbcolor {
    graphicsdict /currgstate get /setspace /DeviceRGB put
    graphicsdict /currgstate get /colorspace /DeviceRGB put
    graphicsdict /currgstate get exch /colorcomp3 exch put
    graphicsdict /currgstate get exch /colorcomp2 exch put
    graphicsdict /currgstate get exch /colorcomp1 exch put
    graphicsdict /currgstate get /sepindex null put
} bind def

/currentrgbcolor {
    ColorConversion /DeviceRGB get
        graphicsdict /currgstate get /colorspace get
        get exec
} bind def

% hue saturation brightness  sethsbcolor  -
% the components are recorded in RGB, converted with the usual
% hexcone model (hue scaled to a sector 0-5; the sector's fractional
% part blends between the derived p, q and t values)
/sethsbcolor {
    7 dict begin
    {/b /s /h}{exch def}forall
    /h h h truncate sub 6 mul def       % wrap hue, scale to sector 0-5
    /i h truncate cvi def
    /f h i sub def
    /p b 1 s sub mul def
    /q b 1 s f mul sub mul def
    /t b 1 s 1 f sub mul sub mul def
    i 0 eq { b t p }{
    i 1 eq { q b p }{
    i 2 eq { p b t }{
    i 3 eq { p q b }{
    i 4 eq { t p b }{
             b p q } ifelse } ifelse } ifelse } ifelse } ifelse
    end
    setrgbcolor
} bind def

/currenthsbcolor {
    currentrgbcolor
    3 dict begin
    {/b /g /r}{exch def}forall
    /v r g 2 copy lt {exch} if pop b 2 copy lt {exch} if pop def
    /d v r g 2 copy gt {exch} if pop b 2 copy gt {exch} if pop sub def
    d 0 eq {
        0 0 v
    }{
        v r eq { g b sub d div 6 add
        }{ v g eq { b r sub d div 2 add
        }{ r g sub d div 4 add } ifelse } ifelse
        6 div dup truncate sub          % hue
        d v div                         % saturation
        v                               % brightness
    } ifelse
    end
} bind def

/setcmykcolor {
    graphicsdict /currgstate get /setspace /DeviceCMYK put
    graphicsdict /currgstate get /colorspace /DeviceCMYK put
    graphicsdict /currgstate get exch /colorcomp4 exch put
    graphicsdict /currgstate get exch /colorcomp3 exch put
    graphicsdict /currgstate get exch /colorcomp2 exch put
    graphicsdict /currgstate get exch /colorcomp1 exch put
    graphicsdict /currgstate get /sepindex null put
} bind def

/currentcmykcolor {
    ColorConversion /DeviceCMYK get
        graphicsdict /currgstate get /colorspace get
        get exec
} bind def

% if PatternType == 1 and PaintType == 2, then color comps will also be passed
/setpattern {
    currentcolorspace 0 get /Pattern ne {
	%[ /Pattern currentcolorspace ] setcolorspace
	/DeviceGrey setcolorspace
	0 setgray
    } if
    setcolor
} bind def

/QUIET where { pop }{ (eof color\n)print } ifelse
