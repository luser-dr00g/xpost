/QUIET where { pop }{ (loading gstate.ps...)print } ifelse

% gstatetemplate yields a freshly-initialized dictionary
% with the following values. currmatrix and scratchmatrix
% are newly-allocated arrays.
/gstatetemplate <<
    % the space as set (what currentcolorspace reports; may be an array)
    /setspace /DeviceGray
    % the space the colour components below are recorded in
    /colorspace /DeviceGray
    /colorcomp1 0
    /colorcomp2 0
    /colorcomp3 0
    /colorcomp4 0
    % a separation colour delivered to a spot-capable device: the
    % device's registry index and the tint, alongside the component
    % values above (which hold the tint-transformed alternate colour
    % for everything that does not preserve separations)
    /sepindex null
    /septint 0
    % the pattern colour: the instantiated pattern dictionary, and for
    % an uncoloured pattern the underlying space and its components
    /patdict null
    /patbase null
    /patcomps null
    % black generation, undercolor removal and the colour rendering
    % dictionary, recorded for round-tripping
    /blackgen {}
    /ucr {}
    /colorrendering 0 dict
    /transfer {}
    % colour transfer functions; the unprefixed grey slot above is
    % shared with settransfer and is the one painting applies
    /redtransfer {}
    /greentransfer {}
    /bluetransfer {}
    % halftone screens: frequency, angle and spot function per
    % component, recorded for currentscreen and currentcolorscreen
    % (continuous-tone rendering takes no effect from them). The
    % unprefixed slots are the grey channel, shared with setscreen.
    /screenfreq 60
    /screenangle 45
    /screenproc { 180 mul cos exch 180 mul cos add 2 div }
    /redscreenfreq 60
    /redscreenangle 45
    /redscreenproc { 180 mul cos exch 180 mul cos add 2 div }
    /greenscreenfreq 60
    /greenscreenangle 45
    /greenscreenproc { 180 mul cos exch 180 mul cos add 2 div }
    /bluescreenfreq 60
    /bluescreenangle 45
    /bluescreenproc { 180 mul cos exch 180 mul cos add 2 div }
    % a halftone installed as a dictionary; null while the screens
    % came from setscreen or setcolorscreen
    /halftone null
    %/currmatrix DEVICE /defaultmatrix get matrix copy
    %/currmatrix [ 1 0 0 1 0 0 ]
    %/scratchmatrix [ 1 0 0 1 0 0 ] % ??
    /currpath .newpathstr
    /clipregion .newpathstr
    /flat 1
    /linewidth 1
    /linecap 0
    /linejoin 0
    /miterlimit 10.0
    /overprint false
    /dasharray []
    /dashoffset 0
    /currfont 1 dict
    /device DEVICE
>> def
/gstatetemplate { //gstatetemplate % use template
    dup /currmatrix [ 1 0 0 1 0 0 ] put  % allocate fresh arrays
    dup /scratchmatrix [ 1 0 0 1 0 0 ] put
} def



% Graphics State Operators -- Device Independent

/deepcopy { % dict1 dict2 . dict2'
    begin
    {
        dup type /arraytype eq
        1 index xcheck not and {
            dup length array
            copy
            def
        }{
            dup type /dicttype eq {
                dup maxlength dict deepcopy
                def
            }{
                def
            } ifelse
        } ifelse
    } forall
    currentdict end
} def

/gstatecopy { % dict1 dict2 . dict2'
    begin
    { % key val
        %pstack()= %1 index =
        dup type /arraytype eq
        1 index xcheck not and { % key val
            1 index % key val key
            currentdict 1 index known { % key val key  (key known in currentdict)
                currentdict exch get % key val dict2-val
                % the existing value only offers reusable storage if it
                % is itself an array (a colour space entry may hold a
                % name in one state and an array in another)
                dup type /arraytype eq {
                    2 copy length exch length exch % key val dict2-val n d2-n
                    le {
                        % reuse the storage, but the entry must take the
                        % subarray copy returns: a shorter value left
                        % behind the old full-length array (a dash set
                        % inside gsave survived its grestore)
                        copy % key dict2-val'
                        def
                    }{
                        pop dup length array
                        copy
                        def
                    } ifelse
                }{
                    pop dup length array
                    copy
                    def
                } ifelse
            }{ % key val key   (key not known in currentdict)
                exch % key key val
                dup length array % key key val val2
                copy % key key val2
                def
                pop
            } ifelse
        }{  % not arraytype
            1 index /currpath eq {
                %1 dict deepcopy % perform deep copy on path dict
                def
            }{
                def
            } ifelse
        } ifelse
    } forall
    currentdict end
} def

% -  gsave  -
% push graphics state
/gsave {
graphicsdict begin
    /gptr gptr 1 add def
    gptr gstackarray length ge { /gsave cvx /limitcheck signalerror } if
    gstackarray gptr gstate currentgstate put % push copy on stack
    currgstate /currpath 2 copy get .copypath put % make a new working copy of path
end
} def

% -  grestore  -
% pop graphics state
/grestore {
graphicsdict begin
    gptr -1 gt {
        gstackarray gptr get
            %dup {exch = ==} forall
        currgstate gstatecopy pop
        gptr 0 gt { %discard all but one element, for grestoreall
            gstackarray gptr null put % discard stack copy
        } if
        /gptr gptr 1 sub def
    } if
end
} def

% -  grestoreall  -
% pop to bottommost graphics state
/grestoreall {
graphicsdict begin
    /gptr -1 def
    gstackarray 0 get
    currgstate gstatecopy pop
end
} def

% -  initgraphics  -
% reset graphics state parameters
/initgraphics {
    break
    gstate setgstate
    initmatrix
    /QUIET where { pop }{ matrix currentmatrix == } ifelse
    %(initclip)=
    initclip
    %(erasepage)=
    erasepage
    %(0 setgray)=
    0 setgray
} def

% -  gstate  gstate
% create graphics state object
/gstate {
    gstatetemplate dup length dict copy
} def

% gstate  setgstate  -
% set graphics state from gstate
/setgstate {
    graphicsdict /currgstate get copy pop
} def

% gstate  currentgstate  gstate
% copy current graphics state into given gstate object
/currentgstate {
    graphicsdict /currgstate get exch gstatecopy
} def

% -  currentfont  dict
% return current font from the graphics state
/currentfont {
    graphicsdict /currgstate get /currfont get
} def

% proc  settransfer  -
% install the transfer procedure for every component
/settransfer {
    graphicsdict /currgstate get exch /transfer exch put
    graphicsdict /currgstate get
    dup dup /transfer get /redtransfer exch put
    dup dup /transfer get /greentransfer exch put
    dup /transfer get /bluetransfer exch put
} def

% -  currenttransfer  proc
% return the grey channel's transfer procedure
/currenttransfer {
    graphicsdict /currgstate get /transfer get
} def

% black generation and undercolor removal (recorded only: painting
% converts by the additive-complement formulae), and the colour
% rendering dictionary (recorded only)
/setblackgeneration {
    graphicsdict /currgstate get exch /blackgen exch put
} def
/currentblackgeneration {
    graphicsdict /currgstate get /blackgen get
} def
/setundercolorremoval {
    graphicsdict /currgstate get exch /ucr exch put
} def
/currentundercolorremoval {
    graphicsdict /currgstate get /ucr get
} def
/setcolorrendering {
    graphicsdict /currgstate get exch /colorrendering exch put
} def
/currentcolorrendering {
    graphicsdict /currgstate get /colorrendering get
} def

% string  findcolorrendering  name bool
% one rendering serves every condition: the default instance
/findcolorrendering { pop /DefaultColorRendering true } def
currentglobal true setglobal
/DefaultColorRendering 0 dict dup /ColorRenderingType 1 put
/ColorRendering defineresource pop
setglobal

% flag  setstrokeadjust  -   (recorded only)
/setstrokeadjust {
    graphicsdict /currgstate get exch /strokeadjust exch put
} def
/currentstrokeadjust {
    graphicsdict /currgstate get /strokeadjust 2 copy known
        { get }{ pop pop false } ifelse
} def

% num  setsmoothness  -   (recorded only)
/setsmoothness {
    graphicsdict /currgstate get exch /smoothness exch put
} def
/currentsmoothness {
    graphicsdict /currgstate get /smoothness 2 copy known
        { get }{ pop pop 0.02 } ifelse
} def

% redproc greenproc blueproc grayproc  setcolortransfer  -
% record one transfer procedure per component; the grey channel
% shares its slot with settransfer, and is the one painting applies
/setcolortransfer {
    graphicsdict /currgstate get exch /transfer exch put
    graphicsdict /currgstate get exch /bluetransfer exch put
    graphicsdict /currgstate get exch /greentransfer exch put
    graphicsdict /currgstate get exch /redtransfer exch put
} def

% -  currentcolortransfer  redproc greenproc blueproc grayproc
% return every component's transfer procedure
/currentcolortransfer {
    graphicsdict /currgstate get /redtransfer get
    graphicsdict /currgstate get /greentransfer get
    graphicsdict /currgstate get /bluetransfer get
    graphicsdict /currgstate get /transfer get
} def

% copy the grey screen to the colour channels: setscreen installs one
% screen for every component
/.spreadgrayscreen {
    graphicsdict /currgstate get
    dup dup /screenfreq get /redscreenfreq exch put
    dup dup /screenangle get /redscreenangle exch put
    dup dup /screenproc get /redscreenproc exch put
    dup dup /screenfreq get /greenscreenfreq exch put
    dup dup /screenangle get /greenscreenangle exch put
    dup dup /screenproc get /greenscreenproc exch put
    dup dup /screenfreq get /bluescreenfreq exch put
    dup dup /screenangle get /bluescreenangle exch put
    dup /screenproc get /bluescreenproc exch put
} def

% sample a spot function across its halftone cell, one call per
% device pixel the cell spans: the language evaluates the spot
% function when the screen is installed, and programs lean on the
% side effects (the classic pattern-cell idiom counts its bits
% there), so the calls must happen even though rendering stays
% continuous tone
/.samplespot { % freq proc  .  -
    4 dict begin
    /proc exch def
    /freq exch def
    /n DEVICE /defaultmatrix get 0 get abs 72 mul freq div
       round cvi dup 1 lt { pop 1 } if dup 64 gt { pop 64 } if def
    0 1 n 1 sub { /i exch def
        0 1 n 1 sub { /j exch def
            % restore the operand depth around the call: only the
            % side effects are wanted, whatever the procedure leaves
            count /d0 exch def
            i 0.5 add n div 2 mul 1 sub
            j 0.5 add n div 2 mul 1 sub
            proc
            count d0 sub dup 0 gt { { pop } repeat }{ pop } ifelse
        } for
    } for
    end
} def

% The threshold cell of a screening device. A bilevel device that
% declares /ScreenPaint takes a cell built from the current screen:
% the spot function samples across the cell and the pixels rank by
% spot value, the lowest whitening first -- highlight dots open at
% the spot minima, and the shadow dot at the maximum darkens last --
% so each pixel's threshold is its rank.
% The painting machinery refreshes the cell before it marks, so the
% screen in force is the one the paint sees.

% freq ang proc  .installscreencell  -
% The screen tiles the device plane on a rotated integer lattice:
% the angle becomes the nearest rational tangent b/a with the cell
% diagonal near the requested frequency, the lattice vectors (a,b)
% and (-b,a) map every device pixel into its cell, and the whole
% repeating tile ranks together, the lowest spot values whitening
% first. An axis-aligned screen falls out as b = 0.
/.gcd { % m n .gcd g
    { dup 0 eq { pop exit } if exch 1 index mod } loop
} def
/.installscreencell {
    20 dict begin
    /proc exch def /ang exch def /freq exch def
    /n DEVICE /defaultmatrix get 0 get abs 72 mul freq div
       round cvi dup 2 lt { pop 2 } if dup 48 gt { pop 48 } if def
    % the lattice needs the angle only modulo ninety degrees, but the
    % spot pattern need not have the cell's symmetry: the whole
    % quarter turns rotate the spot's argument instead
    /th ang 90 div dup floor sub 90 mul def
    /quad ang 90 div floor cvi 4 mod dup 0 lt { 4 add } if def
    /besta n def /bestb 0 def /bestscore 1e9 def
    0 1 24 { /aa exch def
        0 1 24 { /bb exch def
            aa 0 eq bb 0 eq and not {
                /cand bb aa atan dup 90 ge { 90 sub } if def
                /sz aa dup mul bb dup mul add sqrt def
                /per aa dup mul bb dup mul add
                     aa abs bb abs .gcd idiv def
                per 64 le sz 1.5 ge and {
                    /score cand th sub abs
                           sz n sub abs n div 30 mul add def
                    score bestscore lt {
                        /bestscore score def
                        /besta aa def /bestb bb def
                    } if
                } if
            } if
        } for
    } for
    /a besta def /b bestb def
    /q a dup mul b dup mul add def
    /L q a abs b abs .gcd idiv def
    /vals L L mul array def
    % arguments stay strictly inside (-1 1) whatever their sign: a
    % program may fold a negation into its spot, and the closed end
    % of the domain would come back around
    /.clamparg {
        dup -0.999 lt { pop -0.999 } if
        dup 0.999 gt { pop 0.999 } if
    } def
    0 1 L 1 sub { /y exch def
        0 1 L 1 sub { /x exch def
            % the sample point sits at the pixel centre, nudged just
            % off the symmetric positions, so a symmetric spot orders
            % its near-equal values by its own topology instead of
            % leaving runs of exact ties whose sort order, not the
            % spot, would shape the dot
            /xs x 0.5071 add def
            /ys y 0.4877 add def
            % the cell holding the pixel, and that cell's centre
            % snapped to the nearest pixel centre: measuring the
            % argument from the snapped centre rounds each dot about
            % one pixel rather than squaring it about a corner, and
            % keeps a table-indexing spot reading the entry under
            % the pixel, never the seam between two
            /m1 a xs mul b ys mul add q div floor def
            /m2 a ys mul b xs mul sub q div floor def
            /xc a m1 0.5 add mul b m2 0.5 add mul sub floor 0.5 add def
            /yc b m1 0.5 add mul a m2 0.5 add mul add floor 0.5 add def
            count /d0 exch def
            a xs xc sub mul b ys yc sub mul add q div 2 mul
            dup 1 ge { 2 sub } if dup -1 lt { 2 add } if .clamparg
            a ys yc sub mul b xs xc sub mul sub q div 2 mul
            dup 1 ge { 2 sub } if dup -1 lt { 2 add } if .clamparg
            quad { exch neg } repeat
            proc
            count d0 sub
            dup 0 le { pop 0 }{ 1 sub { exch pop } repeat } ifelse
            vals y L mul x add 3 -1 roll put
        } for
    } for
    /idx L L mul array def
    0 1 idx length 1 sub { dup idx 3 1 roll put } for
    % equal spot values rank in sample order, so a flat run of the
    % spot -- a line screen's column, a pattern's plateau -- whitens
    % coherently instead of in the sort's incidental order
    idx { 2 copy vals exch get exch vals exch get
          2 copy eq { pop pop lt }{ exch lt 3 1 roll pop pop } ifelse
    } qsort
    % when the tile holds several cells, deal the ranks around them:
    % each cell takes every nth rank in its own value order, so a
    % shell of equal spot values splits evenly and every cell grows
    % the same dot, one pixel at a time
    /g a abs b abs .gcd def
    /nc q g idiv g idiv def
    nc 1 gt {
        /ap a g idiv def
        /bp b g idiv def
        /ctr nc array def
        0 1 nc 1 sub { ctr exch 0 put } for
        /idx2 L L mul array def
        0 1 idx length 1 sub { /r exch def
            /i idx r get def
            /ix i L mod def
            /iy i L idiv def
            /m1 a ix mul b iy mul add q div floor cvi def
            /m2 a iy mul b ix mul sub q div floor cvi def
            /cid ap m1 mul bp m2 mul sub nc mod
                 dup 0 lt { nc add } if def
            idx2 ctr cid get nc mul cid add i put
            ctr cid 2 copy get 1 add put
        } for
        /idx idx2 def
    } if
    /cell L L mul string def
    % a pixel whitens when the grey level, on the painters' 0..256
    % halftone scale, reaches its threshold; rank r takes the first
    % level past r whitened pixels' worth of grey, so an even tint
    % splits a line screen's cell without a stray pixel and the
    % extremes stay solid
    0 1 idx length 1 sub { /r exch def
        cell idx r get
        r 256 mul idx length div cvi 1 add
        dup 255 gt { pop 255 } if
        put
    } for
    DEVICE /.htcell cell put
    DEVICE /.htw L put
    DEVICE /.hth L put
    % fetched, not looked up: a bare name would run the procedure
    DEVICE /.htsrc currentdict /proc get put
    DEVICE /.htfreq freq put
    DEVICE /.htang ang put
    end
} def

% -  .refreshscreencell  -
% bring a screening device's cell up to the screen in force: the
% installed halftone dictionary's thresholds or spot function, else
% the screen triple, rebuilt only when it has changed
/.refreshscreencell {
    DEVICE /ScreenPaint known {
        4 dict begin
        /ht graphicsdict /currgstate get /halftone get def
        ht null ne {
            ht /Thresholds 2 copy known { get }{ pop pop null } ifelse
            dup type /stringtype eq {
                /th exch def
                DEVICE /.htsrc 2 copy known { get }{ pop pop null } ifelse
                th eq not {
                    DEVICE /.htcell th put
                    DEVICE /.htw ht /Width get put
                    DEVICE /.hth ht /Height get put
                    DEVICE /.htsrc th put
                } if
            }{
                pop
                ht /SpotFunction 2 copy known { get }{ pop pop null } ifelse
                dup null ne {
                    /sp exch def
                    DEVICE /.htsrc 2 copy known { get }{ pop pop null } ifelse
                    currentdict /sp get eq not {
                        ht /Frequency 2 copy known { get }{ pop pop 60 } ifelse
                        ht /Angle 2 copy known { get }{ pop pop 0 } ifelse
                        currentdict /sp get .installscreencell
                    } if
                }{ pop } ifelse
            } ifelse
        }{
            DEVICE /.htsrc 2 copy known { get }{ pop pop null } ifelse
                graphicsdict /currgstate get /screenproc get eq
            DEVICE /.htfreq 2 copy known { get }{ pop pop null } ifelse
                graphicsdict /currgstate get /screenfreq get eq and
            DEVICE /.htang 2 copy known { get }{ pop pop null } ifelse
                graphicsdict /currgstate get /screenangle get eq and
            not {
                graphicsdict /currgstate get /screenfreq get
                graphicsdict /currgstate get /screenangle get
                graphicsdict /currgstate get /screenproc get
                .installscreencell
            } if
        } ifelse
        end
    } if
} def

% freq angle proc  setscreen  -
% record the halftone screen for every component and evaluate the
% spot function across the cell. xpost renders continuous tone, so
% the screen does not affect the raster; the parameters are part of
% the graphics state and round-trip through currentscreen and
% currentcolorscreen
/setscreen {
    graphicsdict /currgstate get exch /screenproc exch put
    graphicsdict /currgstate get exch /screenangle exch put
    graphicsdict /currgstate get exch /screenfreq exch put
    graphicsdict /currgstate get /halftone null put
    .spreadgrayscreen
    graphicsdict /currgstate get /screenfreq get dup 0 gt {
        graphicsdict /currgstate get /screenproc get
        dup xcheck { .samplespot }{ pop pop } ifelse
    }{ pop } ifelse
} def

% -  currentscreen  freq angle proc
% return the grey channel's screen parameters
/currentscreen {
    graphicsdict /currgstate get /screenfreq get
    graphicsdict /currgstate get /screenangle get
    graphicsdict /currgstate get /screenproc get
} def

% rf ra rp gf ga gp bf ba bp kf ka kp  setcolorscreen  -
% record one screen per component; the grey channel shares its slots
% with setscreen
/setcolorscreen {
    graphicsdict /currgstate get exch /screenproc exch put
    graphicsdict /currgstate get exch /screenangle exch put
    graphicsdict /currgstate get exch /screenfreq exch put
    graphicsdict /currgstate get exch /bluescreenproc exch put
    graphicsdict /currgstate get exch /bluescreenangle exch put
    graphicsdict /currgstate get exch /bluescreenfreq exch put
    graphicsdict /currgstate get exch /greenscreenproc exch put
    graphicsdict /currgstate get exch /greenscreenangle exch put
    graphicsdict /currgstate get exch /greenscreenfreq exch put
    graphicsdict /currgstate get exch /redscreenproc exch put
    graphicsdict /currgstate get exch /redscreenangle exch put
    graphicsdict /currgstate get exch /redscreenfreq exch put
    graphicsdict /currgstate get /halftone null put
} def

% halftonedict  sethalftone  -
% record the halftone dictionary. Every screen channel then answers
% the dictionary itself in the spot-function position: behind its own
% frequency and angle for a type 1 dictionary, behind 60 and 0 for
% any other type
/sethalftone {
    dup type /dicttype ne {
        /sethalftone cvx /typecheck signalerror
    } if
    graphicsdict /currgstate get exch /halftone exch put
    1 dict begin
    /ht graphicsdict /currgstate get /halftone get def
    ht /HalftoneType 2 copy known { get 1 eq }{ pop pop false } ifelse
    ht /Frequency known and ht /Angle known and {
        graphicsdict /currgstate get /screenfreq ht /Frequency get put
        graphicsdict /currgstate get /screenangle ht /Angle get put
    }{
        graphicsdict /currgstate get /screenfreq 60 put
        graphicsdict /currgstate get /screenangle 0 put
    } ifelse
    graphicsdict /currgstate get /screenproc ht put
    % a threshold-array halftone may deliver its thresholds through a
    % file (a filter over the program stream): sethalftone consumes
    % that data, so drain it, or the interpreter would execute the
    % thresholds as program text
    ht /Thresholds 2 copy known {
        get dup type /filetype eq {
            { dup 4096 string readstring not { exit } if pop } loop
            pop
        }{ pop } ifelse
    }{ pop pop } ifelse
    end
    .spreadgrayscreen
} def

% -  currenthalftone  halftonedict
% return the halftone: the installed dictionary, or a type 1
% dictionary over the grey screen when the screens were set directly
/currenthalftone {
    graphicsdict /currgstate get /halftone get
    dup null eq {
        pop
        << /HalftoneType 1
           /Frequency graphicsdict /currgstate get /screenfreq get
           /Angle graphicsdict /currgstate get /screenangle get
           /SpotFunction graphicsdict /currgstate get /screenproc get
        >>
    } if
} def

% -  currentcolorscreen  rf ra rp gf ga gp bf ba bp kf ka kp
% return every component's screen parameters
/currentcolorscreen {
    graphicsdict /currgstate get /redscreenfreq get
    graphicsdict /currgstate get /redscreenangle get
    graphicsdict /currgstate get /redscreenproc get
    graphicsdict /currgstate get /greenscreenfreq get
    graphicsdict /currgstate get /greenscreenangle get
    graphicsdict /currgstate get /greenscreenproc get
    graphicsdict /currgstate get /bluescreenfreq get
    graphicsdict /currgstate get /bluescreenangle get
    graphicsdict /currgstate get /bluescreenproc get
    graphicsdict /currgstate get /screenfreq get
    graphicsdict /currgstate get /screenangle get
    graphicsdict /currgstate get /screenproc get
} def

% num  setlinewidth  -
% set line width
/setlinewidth {
    graphicsdict /currgstate get exch /linewidth exch put
} def

% -  currentlinewidth  num
% return current line width
/currentlinewidth {
    graphicsdict /currgstate get /linewidth get
} def

% int  setlinecap  -
% set shape of the ends for stroke (0=butt, 1=round, 2=square)
/setlinecap {
    graphicsdict /currgstate get exch /linecap exch put
} def

% -  currentlinecap  int
% return current line cap
/currentlinecap {
    graphicsdict /currgstate get /linecap get
} def

% array offset  setdash  -
/setdash {
    graphicsdict /currgstate get exch /dashoffset exch put
    graphicsdict /currgstate get exch /dasharray exch put
} def

% -  currentdash  array offset
/currentdash {
    graphicsdict /currgstate get /dasharray get
    graphicsdict /currgstate get /dashoffset get
} def

% int  setlinejoin  -
% set shape of corners for stroke (0=miter, 1=round, 2=bevel)
/setlinejoin {
    graphicsdict /currgstate get exch /linejoin exch put
} def

% -  currentlinejoin  int
% return current line join
/currentlinejoin {
    graphicsdict /currgstate get /linejoin get
} def

% num  setmiterlimit  -
/setmiterlimit {
    graphicsdict /currgstate get exch /miterlimit exch put
} def

% -  currentmiterlimit  num
/currentmiterlimit {
    graphicsdict /currgstate get /miterlimit get
} def

% bool  setoverprint  -
/setoverprint {
    graphicsdict /currgstate get exch /overprint exch put
} def

% -  currentoverprint  bool
/currentoverprint {
    graphicsdict /currgstate get /overprint get
} def


% Graphics State Operators -- Device Dependent

/setflat {
    /CONSTRAINFLATNESS where{
        pop dup 100 gt{pop 100}if dup .2 lt{pop .2}if } if
    graphicsdict /currgstate get exch /flat exch put
} def

/currentflat {
    graphicsdict /currgstate get /flat get
} def


/QUIET where { pop }{ (eof gstate.ps\n)print } ifelse
