/FontType 1 def
/PaintType 0 def
/FontMatrix [0.001 0 0 0.001 0 0] def
/FontBBox {0 0 1000 1000} def
/Encoding 256 array 0 1 255 {1 index exch /.notdef put} for
dup 65 /sq put readonly def
currentdict end
