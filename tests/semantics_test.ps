(EarlyChange 0 defers the wider code to the table boundary) assert
currentfile /ASCIIHexDecode filter
<< /K -1 /Columns 16 /Rows 4 >> /CCITTFaxDecode filter 16 string readstring
26AE6DCCDC90C0040040>
pop <0FFFF0FFFF0FFFF0> eq
(CCITTFaxDecode expands the two-dimensional coding) assert
currentfile /ASCIIHexDecode filter
<< /K 0 /Columns 16 /Rows 4 /BlackIs1 true >> /CCITTFaxDecode filter
16 string readstring
35645B9CDD90C0040040040040040040>
pop <F0000F0000F0000F> eq
(the one-dimensional coding honours BlackIs1) assert
% --- encode filters: the write-side counterparts ---
/st.f (semantics.scratch) (w) file def
/st.e st.f /ASCIIHexEncode filter def
st.e (Hello) writestring st.e closefile st.f closefile
(semantics.scratch) (r) file 16 string readstring pop
(48656C6C6F>) eq (ASCIIHexEncode writes hex and the closing marker) assert
/st.f (semantics.scratch) (w) file def
/st.e st.f /ASCII85Encode filter def
st.e <00000000010203> writestring st.e closefile st.f closefile
(semantics.scratch) (r) file 16 string readstring pop
(z!<N?~>) eq (ASCII85Encode abbreviates zeros and closes the partial group) assert
/st.f (semantics.scratch) (w) file def
/st.e st.f 0 /RunLengthEncode filter def
st.e (AAAABCCCCC) writestring st.e closefile st.f closefile
(semantics.scratch) (r) file 16 string readstring pop
<FD410042FC4380> eq (RunLengthEncode packs runs and literals) assert
/st.f (semantics.scratch) (w) file def
/st.e st.f 4 /RunLengthEncode filter def
st.e (DDDDDDDD) writestring st.e closefile st.f closefile
(semantics.scratch) (r) file 16 string readstring pop
<FD44FD4480> eq (records bound the runs in RunLengthEncode) assert
/st.data (the rain in spain stays mainly in the plain) def
/st.f (semantics.scratch) (w) file def
/st.e st.f /LZWEncode filter def
st.e st.data writestring st.e closefile st.f closefile
(semantics.scratch) (r) file /LZWDecode filter 64 string readstring pop
st.data eq (LZWEncode round-trips through its decoder) assert
[ (x) ] .flatecompress {
    pop
    /st.f (semantics.scratch) (w) file def
    /st.e st.f /FlateEncode filter def
    st.e st.data writestring st.e closefile st.f closefile
    (semantics.scratch) (r) file /FlateDecode filter 64 string readstring pop
    st.data eq (FlateEncode round-trips through its decoder) assert
}{ pop } ifelse
% cvi and cvr read their string operands with the scanner's token
% semantics: leading white space and anything past the numeral's end
% are ignored, and a token that is not a numeral refuses
(0.5\n) cvr 0.5 (cvr ignores what follows the numeral) assertnear
(  16 pt) cvi 16 eq (cvi skips leading space and trailing text) assert
{ (0.5junk) cvr } stopped { pop pop true }{ false } ifelse
(a glued suffix is no numeral) assert

% the string scanner reads octal escapes as the reference does: at
% most three digits, and octal digits only, so 8 and 9 and any fourth
% digit end the escape. == relies on this to reconstruct what it
% escaped (checked exhaustively by fuzzing, not here)
(\3770) length 2 eq (an octal escape stops after three digits) assert
(\0000) length 2 eq (a full three-digit octal stops at the third) assert
(\09) length 2 eq (8 and 9 are not octal digits) assert
(\128) length 2 eq (a non-octal digit ends the escape) assert
(\101) 0 get 65 eq (three octal digits decode) assert
(\377) 0 get 255 eq (the high octal value decodes) assert
(\0) 0 get 0 eq (a one-digit octal decodes) assert

% cvs of a real produces the shortest decimal that reads back to the
% same value, in the notation the reference interpreters use: fixed
% between 1e-4 and 1e6, scientific outside, a whole value keeping its
% .0. It once emitted full binary-float precision, and a large value
% corrupted a digit.
/st.cvsr { 40 string cvs } def
3.14159 st.cvsr (3.14159) eq (a real formats to the shortest decimal) assert
0.001 st.cvsr (0.001) eq (a small real keeps fixed notation) assert
2.5 st.cvsr (2.5) eq (no trailing zeros) assert
100000.0 st.cvsr (100000.0) eq (a whole real keeps its point below 1e6) assert
1e6 st.cvsr (1e+06) eq (a large real turns scientific at 1e6) assert
1e-5 st.cvsr (1e-05) eq (a tiny real turns scientific below 1e-4) assert
0.0001 st.cvsr (0.0001) eq (1e-4 is the last fixed magnitude) assert
% every formatted real reads back to the value it came from
/st.roundtrips true def
[ 3.14159 0.001 2.5 100000.0 0.5 0.1 42.0 1e10 1e-5 ] {
    dup st.cvsr cvr ne { /st.roundtrips false def } if
} forall
st.roundtrips (a formatted real reads back to itself) assert

% a source that ends inside a procedure is a syntax error, not an
% endless scan: the scanner answers null at end of input and nowhere
% else, a literal null in the text being a name
/st.f (semantics.scratch) (w) file def
st.f (1 2 { 3 4) writestring st.f closefile
{ (semantics.scratch) (r) file cvx exec } stopped
{ $error /errorname get /syntaxerror eq }{ false } ifelse
(a truncated procedure ends the scan) assert
clear
% a complete procedure still scans and runs
/st.f (semantics.scratch) (w) file def
st.f (/st.tp { 6 7 add } def) writestring st.f closefile
(semantics.scratch) (r) file cvx exec
st.tp 13 eq (a closed procedure scans and runs) assert

% a reusable stream built over a decode chain consumes its source
% through the encoding's end, survives being closed -- the position
% rewinds -- and so a program run off it can run again
currentfile << /Filter [ /ASCIIHexDecode ] >> /ReusableStreamDecode filter
2F73742E7273642031372064656620>
/st.rsdp exch def
st.rsdp cvx exec
st.rsd 17 eq (a chained reusable stream delivers its program) assert
userdict /st.rsd undef
st.rsdp 0 setfileposition
st.rsdp cvx exec
st.rsd 17 eq (the stream runs again after its end closed it) assert
% repositioning a closed file is an error, not a crash
/st.f (semantics.scratch) (w) file def
st.f (x) writestring st.f closefile
{ st.f 0 setfileposition } stopped { pop pop true }{ false } ifelse
(repositioning a closed file refuses) assert

% binary object sequences: the writers emit the scanner's encoding,
% gated by the object format parameter, and a sequence round-trips
currentobjectformat 0 eq (the object format starts disabled) assert
{ (x) 0 printobject } stopped { pop pop true }{ false } ifelse
(a disabled format refuses the writers) assert
2 setobjectformat
currentobjectformat 2 eq (setobjectformat records the format) assert
/st.f (semantics.scratch) (w) file def
/st.arr 6 array def
st.arr 0 42 put
st.arr 1 3.25 put
st.arr 2 (hi) put
st.arr 3 /nm put
st.arr 4 [ true null ] put
st.arr 5 mark put
st.f st.arr 7 writeobject
st.f closefile
/st.b (semantics.scratch) (r) file 200 string readstring pop def
st.b 0 get 16#81 eq st.b 1 get 1 eq and
(the sequence heads with its format and count) assert
st.b 2 get st.b 3 get 256 mul add st.b length eq
(the header length spans the sequence) assert
st.b 5 get 7 eq (the tag rides the top-level record) assert
(semantics.scratch) (r) file token
{
    0 get
    dup 0 get 42 eq
    1 index 1 get 3.25 sub abs 0.001 lt and
    1 index 2 get (hi) eq and
    1 index 3 get /nm eq and
    1 index 4 get dup 0 get true eq exch 1 get null eq and and
    1 index 5 get mark eq and
    exch pop
}{ false } ifelse
(a sequence round-trips through the scanner) assert
0 setobjectformat

% DCTEncode, where the JPEG library is present: the stream carries
% the interchange markers, a smooth ramp survives the lossy
% round-trip within a few counts, and a colour image keeps its
% component count
mark
{ /st.f (semantics.scratch) (w) file def
  /st.e st.f << /Columns 16 /Rows 16 /Colors 1 >> /DCTEncode filter def
} stopped { cleartomark false }{ pop true } ifelse
{
    /st.data 256 string def
    0 1 255 { /i exch def
        st.data i i 16 mod i 16 idiv add 8 mul put
    } for
    st.e st.data writestring st.e closefile st.f closefile
    /st.j (semantics.scratch) (r) file 4096 string readstring pop def
    st.j 0 get 16#FF eq st.j 1 get 16#D8 eq and
    st.j dup length 2 sub get 16#FF eq and
    st.j dup length 1 sub get 16#D9 eq and
    (DCTEncode writes a JPEG interchange stream) assert
    /st.rt 256 string def
    (semantics.scratch) (r) file /DCTDecode filter
    st.rt readstring pop pop
    /st.md 0 def
    0 1 255 { /i exch def
        st.rt i get st.data i get sub abs
        dup st.md gt { /st.md exch def }{ pop } ifelse
    } for
    st.md 8 le (a smooth ramp survives the lossy round-trip) assert
    /st.f (semantics.scratch) (w) file def
    /st.e st.f << /Columns 8 /Rows 8 /Colors 3 >> /DCTEncode filter def
    /st.data 192 string def
    0 3 189 { /i exch def
        st.data i 10 put
        st.data i 1 add 200 put
        st.data i 2 add 60 put
    } for
    st.e st.data writestring st.e closefile st.f closefile
    /st.rt 192 string def
    (semantics.scratch) (r) file /DCTDecode filter
    dup st.rt readstring pop length 192 eq
    exch read not and
    (a colour image keeps its component count) assert
    st.rt 96 get 10 sub abs 6 le
    st.rt 97 get 200 sub abs 6 le and
    st.rt 98 get 60 sub abs 6 le and
    (a flat colour survives the transform and quantization) assert
} if
/st.f (semantics.scratch) (w) file def
/st.e st.f << /K -1 /Columns 16 /Rows 4 >> /CCITTFaxEncode filter def
st.e <0FFFF0FFFF0FFFF0> writestring st.e closefile st.f closefile
(semantics.scratch) (r) file 16 string readstring pop
<26AE6DCCDC90C0040040> eq
(CCITTFaxEncode writes the two-dimensional coding) assert
% the mixed coding types each row by a tag bit behind its
% end-of-line marker, and round-trips behind them
/st.f (semantics.scratch) (w) file def
/st.e st.f << /K 2 /Columns 16 /Rows 4 /EndOfLine true >> /CCITTFaxEncode filter def
st.e <F0F00F0FF0F00F0F> writestring st.e closefile st.f closefile
(semantics.scratch) (r) file
<< /K 2 /Columns 16 /Rows 4 >> /CCITTFaxDecode filter
16 string readstring pop <F0F00F0FF0F00F0F> eq
(the mixed coding round-trips behind its markers) assert
% without markers a mixed row carries no tag naming its coding,
% and the stream does not decode
/st.f (semantics.scratch) (w) file def
/st.e st.f << /K 2 /Columns 16 /Rows 4 >> /CCITTFaxEncode filter def
st.e <F0F00F0FF0F00F0F> writestring st.e closefile st.f closefile
(semantics.scratch) (r) file
<< /K 2 /Columns 16 /Rows 4 >> /CCITTFaxDecode filter
16 string readstring exch pop not
(a marker-less mixed stream does not decode) assert

% --- an end-of-line inside a string literal: escaped, it joins
%     the lines; raw, it is one newline character, whichever of
%     the three conventions wrote it ---
(ab\
cd) length 4 eq (an escaped CRLF joins the lines) assert
(ab\
cd) length 4 eq (an escaped bare CR joins the lines) assert
(ab\
cd) length 4 eq (an escaped LF joins the lines) assert
(a
b) dup length 3 eq exch 1 get 10 eq and
(a raw CRLF reads as one newline) assert
(a
b) dup length 3 eq exch 1 get 10 eq and
(a raw CR reads as one newline) assert

% --- an end-of-line marker is one white-space delimiter ---
(ab\r\ncd) token pop exch (cd) eq
    (a CRLF after a token is consumed as one marker) assert
(ab\rcd) token pop exch (cd) eq
    (a bare CR after a token is consumed alone) assert

% --- gcheck holds for simple objects; composites answer for their
%     storage ---
42 gcheck (an integer is a legal element of a global composite) assert
/st.gname gcheck (a name is a simple object under gcheck) assert
[ 1 2 ] gcheck not (a local array is not) assert
currentglobal true setglobal [ 1 2 ] exch setglobal gcheck
(a global array is) assert

% --- bind terminates on a procedure that reaches itself ---
/st.cyc [ 1 2 3 ] cvx def
/st.cyc load 0 /st.cyc load put
/st.cyc load bind type /arraytype eq (bind survives a cyclic procedure) assert

% --- a repeated stencil replays from the run cache cleanly ---
