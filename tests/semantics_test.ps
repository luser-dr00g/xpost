    /BuildChar { pop pop } /FontBBox [0 0 1 1] >> definefont pop
/st.uf undefinefont
FontDirectory /st.uf known not (undefinefont removes the instance) assert
/StandardEncoding findencoding length 256 eq
(findencoding resolves through the Encoding category) assert
(any) findcolorrendering exch /DefaultColorRendering eq and
(findcolorrendering names the default instance) assert
true setstrokeadjust currentstrokeadjust (stroke adjustment is recorded) assert
false setstrokeadjust
0.5 setsmoothness currentsmoothness 0.5 eq (smoothness is recorded) assert
count /st.cd exch def
cachestatus
count st.cd sub 7 eq (cachestatus reports seven values) assert
7 { pop } repeat
/Courier findfont dup setfont
rootfont eq (rootfont answers with the font the program set) assert

% --- user objects index into a growing table ---
3 { 40 2 add } defineuserobject
3 execuserobject 42 eq (a user object executes by index) assert
25 (far) defineuserobject
25 execuserobject (far) eq (the table grows to reach an index) assert
3 execuserobject 42 eq (growth preserves earlier entries) assert
3 undefineuserobject
UserObjects 3 get null eq (undefineuserobject clears the slot) assert

% --- user paths append through both forms ---
newpath
{ 0 0 40 40 setbbox 10 10 moveto 30 30 lineto } uappend
currentpoint 30 eq exch 30 eq and (a self-describing path appends) assert
newpath
[ [0 0 20 20  5 5  1 1  1 1] <00 01 22 04> ] uappend
currentpoint 7 eq exch 7 eq and
(an encoded path repeats its operator by the factor less thirty-two) assert
newpath 1 2 moveto 3 4 lineto
false upath
newpath uappend
currentpoint 4 eq exch 3 eq and (upath round-trips the current path) assert

% --- CIE-based colour reduces through its pipeline to device RGB ---
[ /CIEBasedABC << /WhitePoint [0.9505 1.0 1.089]
   /RangeABC [0 1 0 1 0 1]
   /DecodeABC [ {2.2 exp} bind {2.2 exp} bind {2.2 exp} bind ]
   /MatrixABC [ 0.4124 0.2126 0.0193 0.3576 0.7152 0.1192
                0.1805 0.0722 0.9505 ]
   /RangeLMN [0 0.9505 0 1 0 1.089] >> ] setcolorspace
currentcolorspace 0 get /CIEBasedABC eq (a CIE space reports itself) assert
0.5 0.5 0.5 setcolor
currentrgbcolor
0.5 sub abs 0.02 lt exch 0.5 sub abs 0.02 lt and exch 0.5 sub abs 0.02 lt and
(a calibrated mid grey lands mid grey) assert
1 0 0 setcolor currentrgbcolor pop pop 0.98 gt
(a calibrated red reaches the red channel) assert
[ /CIEBasedA << /WhitePoint [0.9505 1.0 1.089]
   /DecodeA {2.2 exp} bind
   /MatrixA [0.9505 1.0 1.089]
   /RangeLMN [0 0.9505 0 1 0 1.089] >> ] setcolorspace
0.5 setcolor currentrgbcolor
2 { 1 index sub abs 0.005 lt (calibrated grey is neutral) assert } repeat
0.5 sub abs 0.02 lt (and half in comes out half) assert
[ /CIEBasedDEF << /WhitePoint [0.9505 1.0 1.089]
   /Table [ 2 2 2 [ <000000 0000FF 00FF00 00FFFF>
                    <FF0000 FF00FF FFFF00 FFFFFF> ] ]
   /RangeLMN [0 0.9505 0 1 0 1.089]
   /MatrixLMN [0.9505 0 0 0 1 0 0 0 1.089] >> ] setcolorspace
0.5 0.5 0.5 setcolor currentrgbcolor
0.732 sub abs 0.02 lt exch 0.732 sub abs 0.02 lt and exch 0.732 sub abs 0.02 lt and
(the table midpoint interpolates all eight corners) assert
/DeviceGray setcolorspace 0 setgray

