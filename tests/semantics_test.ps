% Object-semantics regression checks, run through `xpost -d null` by
% run-ps-test.sh: prints SUCCESS iff every assertion holds.
%
% Covers:
%   - eq/ne on file objects compare the underlying stream (distinct
%     streams are ne; an object is eq to itself)
%   - pathbbox reports the current path in user space, undoing the CTM

/failcount 0 def
/assert { % bool (name) . -
    exch { pop } { (FAIL: ) print print (\n) print /failcount failcount 1 add def } ifelse
} def
/assertnear { % val expected (name) . -
    3 1 roll sub abs 0.001 lt exch assert
} def

% --- file object comparison ---
/tmpf (%stdout) (w) file def
/diskf (semantics.diskf) (w) file def  % a real disk file (portable: not /dev/null)
diskf tmpf ne (disk file vs stdout are distinct) assert
diskf dup eq (file object equals itself) assert
tmpf dup ne not (stdout object not-ne itself) assert

% --- %stderr is writable ---
{ (%stderr) (w) file (semantics_test: stderr probe\n) writestring true } stopped
{ pop false } if (writestring to %stderr) assert

% --- pathbbox in user space ---
% pathbbox leaves llx lly urx ury; consume top-down
newpath 10 10 moveto 50 10 lineto 50 60 lineto 10 60 lineto closepath
pathbbox
60 (pathbbox ury) assertnear
50 (pathbbox urx) assertnear
10 (pathbbox lly) assertnear
10 (pathbbox llx) assertnear

% under a translated CTM the box must stay in (translated) user space
gsave
100 200 translate
newpath 0 0 moveto 10 0 lineto 10 5 lineto closepath
pathbbox
5 (translated ury) assertnear
10 (translated urx) assertnear
0 (translated lly) assertnear
0 (translated llx) assertnear
grestore

% a moveto that ends the path is only a pending current point (as
% after charpath or a text operator advances it) and stays outside
% the box; a moveto later drawn from counts, and a path holding
% nothing but a moveto is that one point
newpath 0 0 moveto 10 10 lineto 50 60 moveto
pathbbox
10 (trailing moveto ury) assertnear
10 (trailing moveto urx) assertnear
0 (trailing moveto lly) assertnear
0 (trailing moveto llx) assertnear
newpath 0 0 moveto 10 10 lineto 50 60 moveto 20 20 lineto
pathbbox
60 (drawn-from moveto ury) assertnear
50 (drawn-from moveto urx) assertnear
0 (drawn-from moveto lly) assertnear
0 (drawn-from moveto llx) assertnear
newpath 5 7 moveto
pathbbox
7 (only-moveto ury) assertnear
5 (only-moveto urx) assertnear
7 (only-moveto lly) assertnear
5 (only-moveto llx) assertnear

% --- currentfile returns a literal file: programs stash it under a
%     name and the later lookup must push the stashed file, not
%     resume executing it ---
currentfile xcheck not (currentfile carries the literal attribute) assert
/cfstash currentfile def
cfstash type /filetype eq (a stashed currentfile recalls as a file) assert

% --- ReusableStreamDecode buffers its whole source at construction
%     and replays it from any position ---
currentfile /ASCIIHexDecode filter /ReusableStreamDecode filter
48656C6C6F>
/rsdstash exch def
rsdstash 5 string readstring pop (Hello) eq
(a reusable stream reads its data) assert
rsdstash resetfile
rsdstash 5 string readstring pop (Hello) eq
(resetfile replays a reusable stream) assert
rsdstash 2 setfileposition
rsdstash fileposition 2 eq (fileposition reports the reusable position) assert
rsdstash 3 string readstring pop (llo) eq
(setfileposition repositions a reusable stream) assert

% --- ASCII base-85 string literals decode in the scanner ---
<~87cURD]hD=6i~> (Hello CID) eq (a base-85 literal decodes) assert
<~z~> <00000000> eq (z abbreviates four zero bytes) assert

% --- clipsave and cliprestore stack the clip region alone ---
gsave
newpath 10 10 moveto 50 10 lineto 50 50 lineto 10 50 lineto closepath clip
clipsave
newpath 20 20 moveto 30 20 lineto 30 30 lineto 20 30 lineto closepath clip
gsave clippath flattenpath pathbbox grestore
pop pop pop 20 sub abs 0.5 lt (an inner clip narrows the region) assert
cliprestore
gsave clippath flattenpath pathbbox grestore
pop pop pop 10 sub abs 0.5 lt (cliprestore reopens the outer region) assert
grestore

% --- real indices truncate in the string operators: a real-valued
%     loop counter produces fractional indices ---
(ab) 1.0 get 98 eq (a real index truncates in get) assert
/st.co 2 string def
st.co 0.0 65.0 put
st.co 0 get 65 eq (a real index and value truncate in put) assert
[ 5 6 7 ] 1.0 get 6 eq (a real index truncates in array get) assert
/st.ca 2 array def
st.ca 1.0 42 put
st.ca 1 get 42 eq (a real index truncates in array put) assert
% black generation, undercolor removal and colour rendering record
% and report round-trip
{ 0.5 mul } setblackgeneration
4 currentblackgeneration exec 2 eq (blackgeneration round-trips) assert
{ 0.25 mul } setundercolorremoval
8 currentundercolorremoval exec 2 eq (undercolorremoval round-trips) assert

% --- resource machinery: instances per category, private categories
%     registered by defining into /Category ---
currentglobal true setglobal
/Generic /Category findresource type /dicttype eq (Generic category exists) assert
/Generic /Category findresource dup length 1 add dict copy
dup /Category /st.private put
/st.private exch /Category defineresource pop
/st.key << /v 42 >> /st.private defineresource /v get 42 eq (defineresource returns the instance) assert
/st.key /st.private findresource /v get 42 eq (findresource retrieves the instance) assert
/st.key /st.private resourcestatus { pop pop true } { false } ifelse (resourcestatus finds it) assert
setglobal
% --- instances defined in local VM shadow global ones and go away
%     with restore ---
/StandardEncoding /Encoding findresource length 256 eq
(the Encoding category serves the standard encodings) assert
save
/st.linst [ 1 2 3 ] /Encoding defineresource pop
/st.linst /Encoding findresource length 3 eq (a local instance resolves) assert
/st.linst /Encoding resourcestatus { pop pop true }{ false } ifelse
(a local instance reports status) assert
restore
/st.linst /Encoding resourcestatus { pop pop false }{ true } ifelse
(restore removes a local instance) assert
currentglobal true setglobal
/st.other /st.private resourcestatus { pop pop false } { true } ifelse (resourcestatus rejects the unknown) assert
/st.aa 1 /st.private defineresource pop
/st.ab 2 /st.private defineresource pop
/st.bb 3 /st.private defineresource pop
[ (*) { dup length string copy } 32 string /st.private resourceforall ]
length 4 eq (resourceforall enumerates every instance) assert
[ (st.a*) { dup length string copy } 32 string /st.private resourceforall ]
length 2 eq (resourceforall filters by a star template) assert
[ (st.?b) { dup length string copy } 32 string /st.private resourceforall ]
length 2 eq (a ? in the template matches any one character) assert
[ (st.key) { dup length string copy } 32 string /st.private resourceforall ]
length 1 eq (a literal template matches exactly one) assert
[ (none*) { dup length string copy } 32 string /st.private resourceforall ]
length 0 eq (an unmatched template enumerates nothing) assert
[ (st.priv*) { dup length string copy } 32 string /Category resourceforall ]
length 1 eq (resourceforall enumerates categories) assert
/st.aa /st.private undefineresource
/st.ab /st.private undefineresource
/st.bb /st.private undefineresource
/st.key /st.private undefineresource
/st.key /st.private resourcestatus { pop pop false } { true } ifelse (undefineresource removes it) assert
count /st.d0 exch def
{ /st.key /st.ghost findresource } stopped
{ count st.d0 sub { pop } repeat $error /errorname get /undefinedresource eq }
{ count st.d0 sub { pop } repeat false } ifelse
(a missing category reports undefinedresource) assert
setglobal

% --- binary tokens (PLRM 3.14.2): every encoding a packaged program
%     body uses, plus the sibling byte orders ---
<8820> cvx exec 32 eq (int8) assert
<88E0> cvx exec -32 eq (int8 negative) assert
<860100> cvx exec 256 eq (int16 high order) assert
<870001> cvx exec 256 eq (int16 low order) assert
<8400010000> cvx exec 65536 eq (int32 high order) assert
<8500000100> cvx exec 65536 eq (int32 low order) assert
<84FFFFFFFF> cvx exec -1 eq (int32 negative) assert
<8A3F800000> cvx exec 1.0 eq (real IEEE high order) assert
<8B0000803F> cvx exec 1.0 eq (real IEEE low order) assert
<8D01> cvx exec true eq (boolean) assert
<8E03414243> cvx exec (ABC) eq (string, 1-byte length) assert
<8F0003414243> cvx exec (ABC) eq (string, 2-byte length) assert
<9100> cvx exec /abs eq (literal system name) assert
-5 <9200> cvx exec 5 eq (executable system name executes) assert
% a binary token byte delimits the token it follows
<747275658820> cvx exec 32 eq exch true eq and (binary byte delimits a name token) assert
% inside a deferred procedure body
<7B20880A203320616464207D> cvx exec exec 13 eq (binary token inside a procedure) assert

% --- ASCII85Decode filter over the executing file: the program resumes
%     after the end-of-data marker, as packaged bodies require ---
currentfile /ASCII85Decode filter cvx exec
04?gtE,ol+AKY282BXt<+?))!3%uI70O5f3AS)8~>
a85probe length 5 eq (filtered definition arrived) assert
a85probe 0 get 66 eq (filtered content decodes) assert
% and a binary token delivered through the filter
currentfile /ASCII85Decode filter cvx exec
04?gt@VK_%DegJO.Ni85AdS~>
a85bintok 42 eq (binary token through the filter) assert

% --- decode filters ---
currentfile /ASCIIHexDecode filter cvx exec
2F73742E68657876616C2034322064656620>
st.hexval 42 eq (ASCIIHexDecode delivers and the file resumes after the marker) assert
currentfile 1 (*EOD*) /SubFileDecode filter cvx exec
/st.sub 7 def *EOD*
st.sub 7 eq (SubFileDecode ends at the delimiter and the file resumes after it) assert
/st.f (semantics.scratch) (w) file def
st.f <014142FD4380> writestring st.f closefile
(semantics.scratch) (r) file /RunLengthDecode filter
16 string readstring pop (ABCCCC) eq (RunLengthDecode expands runs) assert
[ (squeeze me please, twenty-six letters and then some more) ] .flatecompress {
    /st.chunks exch def
    /st.f (semantics.scratch) (w) file def
    st.chunks { st.f exch writestring } forall st.f closefile
    (semantics.scratch) (r) file /FlateDecode filter
    64 string readstring pop
    (squeeze me please, twenty-six letters and then some more) eq
    (FlateDecode round-trips the compressor) assert
}{ pop } ifelse
currentfile /ASCIIHexDecode filter /LZWDecode filter 100 string readstring
80120CA6C361BC406881C160F0983130B457101DCDE7236190590B82418C267309A4DC20309B8C9208E47A412292474DC21808>
pop (Hello hello hello LZW world, hello again and again and again!) eq
(LZWDecode expands a compressed stream and the file resumes after it) assert
